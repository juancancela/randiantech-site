---
import Socials from "./Socials.astro";

const currentYear = new Date().getFullYear();

export interface Props {
  noMarginTop?: boolean;
}

const { noMarginTop = false } = Astro.props;
---

<footer class={`${noMarginTop ? "" : "mt-auto"}`}>
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="logo-link">
          <span class="logo-r">Randian</span><span class="logo-t">tech</span>
        </a>
        <p class="footer-desc">
          AI consulting, enterprise training, and staff augmentation.
        </p>
      </div>
      <div class="footer-links-grid">
        <div>
          <div class="footer-col-title">Company</div>
          <a href="/about/">About</a>
          <a href="/team/">Team</a>
          <a href="/careers/">Careers</a>
        </div>
        <div>
          <div class="footer-col-title">Resources</div>
          <a href="/services/">Services</a>
          <a href="/contact/">Contact</a>
        </div>
        <div>
          <div class="footer-col-title">Legal</div>
          <a href="/privacy/">Privacy</a>
          <a href="/tos/">Terms</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="copyright">
        &copy; {currentYear} Randiantech. All rights reserved.
      </div>
      <Socials centered />
    </div>
  </div>
</footer>

<style>
  footer {
    @apply w-full border-t border-skin-line;
  }
  .footer-inner {
    @apply mx-auto max-w-5xl px-6 py-12;
  }
  .footer-top {
    @apply flex flex-col gap-10 sm:flex-row sm:justify-between;
  }
  .footer-brand {
    @apply max-w-xs;
  }
  .logo-link {
    @apply text-xl font-bold tracking-tight no-underline;
  }
  .logo-r {
    color: rgb(var(--color-text-base));
    font-weight: 700;
  }
  .logo-t {
    color: rgb(var(--color-accent));
    font-weight: 800;
  }
  .footer-desc {
    @apply mt-3 text-sm text-skin-base/60;
  }
  .footer-links-grid {
    @apply grid grid-cols-3 gap-8;
  }
  .footer-links-grid div {
    @apply flex flex-col gap-2;
  }
  .footer-col-title {
    @apply mb-1 text-xs font-semibold uppercase tracking-wider text-skin-base/40;
  }
  .footer-links-grid a {
    @apply text-sm text-skin-base/70 no-underline transition-colors hover:text-skin-accent;
  }
  .footer-bottom {
    @apply mt-10 flex flex-col-reverse items-center justify-between gap-4 border-t border-skin-line pt-6 sm:flex-row;
  }
  .copyright {
    @apply text-xs text-skin-base/40;
  }
</style>
