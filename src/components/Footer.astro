---
import Socials from "./Socials.astro";
import { getLocaleFromUrl } from "../i18n/utils";
import translations from "../i18n/translations";

const currentYear = new Date().getFullYear();
const locale = getLocaleFromUrl(Astro.url);
const t = translations[locale].footer;
const nav = translations[locale].nav;
const prefix = locale === "es" ? "/es" : "";

export interface Props {
  noMarginTop?: boolean;
}

const { noMarginTop = false } = Astro.props;
---

<footer class={`${noMarginTop ? "" : "mt-auto"}`}>
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <a href={`${prefix}/`} class="logo-link">
          <span class="logo-r">Randian</span><span class="logo-t">tech</span>
        </a>
        <p class="footer-desc">{t.desc}</p>
      </div>
      <div class="footer-links-grid">
        <div>
          <div class="footer-col-title">{t.company}</div>
          <a href={`${prefix}/about/`}>{nav.about}</a>
          <a href={`${prefix}/team/`}>{nav.team}</a>
          <a href={`${prefix}/careers/`}>{nav.careers}</a>
        </div>
        <div>
          <div class="footer-col-title">{t.resources}</div>
          <a href={`${prefix}/services/`}>{nav.services}</a>
          <a href={`${prefix}/contact/`}>{nav.contact}</a>
        </div>
        <div>
          <div class="footer-col-title">{t.legal}</div>
          <a href={`${prefix}/privacy/`}>{t.privacy}</a>
          <a href={`${prefix}/tos/`}>{t.terms}</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="copyright">
        &copy; {currentYear} {t.copyright}
      </div>
      <Socials centered />
    </div>
  </div>
</footer>

<style>
  footer {
    @apply w-full border-t border-skin-line;
  }
  .footer-inner {
    @apply mx-auto max-w-5xl px-6 py-12;
  }
  .footer-top {
    @apply flex flex-col gap-10 sm:flex-row sm:justify-between;
  }
  .footer-brand {
    @apply max-w-xs;
  }
  .logo-link {
    @apply text-xl font-bold tracking-tight no-underline;
  }
  .logo-r { color: rgb(var(--color-text-base)); font-weight: 700; }
  .logo-t { color: rgb(var(--color-accent)); font-weight: 800; }
  .footer-desc {
    @apply mt-3 text-sm text-skin-base/60;
  }
  .footer-links-grid {
    @apply grid grid-cols-3 gap-8;
  }
  .footer-links-grid div {
    @apply flex flex-col gap-2;
  }
  .footer-col-title {
    @apply mb-1 text-xs font-semibold uppercase tracking-wider text-skin-base/40;
  }
  .footer-links-grid a {
    @apply text-sm text-skin-base/70 no-underline transition-colors hover:text-skin-accent;
  }
  .footer-bottom {
    @apply mt-10 flex flex-col-reverse items-center justify-between gap-4 border-t border-skin-line pt-6 sm:flex-row;
  }
  .copyright {
    @apply text-xs text-skin-base/40;
  }
</style>
