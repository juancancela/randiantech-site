---
import { LOGO_IMAGE, SITE } from "@config";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { getLocaleFromUrl } from "../i18n/utils";
import translations from "../i18n/translations";

export interface Props {
  activeNav?: "about" | "services" | "contact" | "team" | "careers";
}

const { activeNav } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const t = translations[locale].nav;
const prefix = locale === "es" ? "/es" : "";
---

<header>
  <a id="skip-to-content" href="#main-content">Skip to content</a>
  <div class="header-container">
    <div class="header-inner">
      <a href={`${prefix}/`} class="logo whitespace-nowrap">
        {
          LOGO_IMAGE.enable ? (
            <img
              src={`/assets/${LOGO_IMAGE.svg ? "logo.svg" : "logo.png"}`}
              alt={SITE.title}
              width={LOGO_IMAGE.width}
              height={LOGO_IMAGE.height}
            />
          ) : (
            <span class="logo-wordmark" aria-label={SITE.title}>
              <span class="logo-r">Randian</span><span class="logo-t">tech</span>
            </span>
          )
        }
      </a>
      <nav id="nav-menu">
        <button
          class="hamburger-menu focus-outline"
          aria-label="Open Menu"
          aria-expanded="false"
          aria-controls="menu-items"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="menu-icon"
          >
            <line x1="7" y1="12" x2="21" y2="12" class="line"></line>
            <line x1="3" y1="6" x2="21" y2="6" class="line"></line>
            <line x1="12" y1="18" x2="21" y2="18" class="line"></line>
            <line x1="18" y1="6" x2="6" y2="18" class="close"></line>
            <line x1="6" y1="6" x2="18" y2="18" class="close"></line>
          </svg>
        </button>
        <ul id="menu-items" class="display-none sm:flex">
          <li>
            <a href={`${prefix}/services/`} class={activeNav === "services" ? "active" : ""}>{t.services}</a>
          </li>
          <li>
            <a href={`${prefix}/about/`} class={activeNav === "about" ? "active" : ""}>{t.about}</a>
          </li>
          <li>
            <a href={`${prefix}/team/`} class={activeNav === "team" ? "active" : ""}>{t.team}</a>
          </li>
          <li>
            <a href={`${prefix}/careers/`} class={activeNav === "careers" ? "active" : ""}>{t.careers}</a>
          </li>
          <li>
            <a href={`${prefix}/contact/`} class={activeNav === "contact" ? "active" : ""}>{t.contact}</a>
          </li>
          <li class="nav-icon-item">
            <LanguageSwitcher />
          </li>
          <li class="nav-icon-item">
            {
              SITE.lightAndDarkMode && (
                <button
                  id="theme-btn"
                  class="focus-outline"
                  title="Toggles light & dark"
                  aria-label="auto"
                  aria-live="polite"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" id="moon-svg" viewBox="0 0 24 24" class="theme-icon">
                    <path d="M20.742 13.045a8.088 8.088 0 0 1-2.077.271c-2.135 0-4.14-.83-5.646-2.336a8.025 8.025 0 0 1-2.064-7.723A1 1 0 0 0 9.73 2.034a10.014 10.014 0 0 0-4.489 2.582c-3.898 3.898-3.898 10.243 0 14.143a9.937 9.937 0 0 0 7.072 2.93 9.93 9.93 0 0 0 7.07-2.929 10.007 10.007 0 0 0 2.583-4.491 1.001 1.001 0 0 0-1.224-1.224Zm-2.772 4.301a7.947 7.947 0 0 1-5.656 2.343 7.953 7.953 0 0 1-5.658-2.344c-3.118-3.119-3.118-8.195 0-11.314a7.923 7.923 0 0 1 2.06-1.483 10.027 10.027 0 0 0 2.89 7.848 9.972 9.972 0 0 0 7.848 2.891 8.036 8.036 0 0 1-1.484 2.059Z" />
                  </svg>
                  <svg xmlns="http://www.w3.org/2000/svg" id="sun-svg" viewBox="0 0 24 24" class="theme-icon">
                    <path d="M6.993 12c0 2.761 2.246 5.007 5.007 5.007s5.007-2.246 5.007-5.007S14.761 6.993 12 6.993 6.993 9.239 6.993 12zM12 8.993c1.658 0 3.007 1.349 3.007 3.007S13.658 15.007 12 15.007 8.993 13.658 8.993 12 10.342 8.993 12 8.993zM10.998 19h2v3h-2zm0-17h2v3h-2zm-9 9h3v2h-3zm17 0h3v2h-3zM4.219 18.363l2.12-2.122 1.415 1.414-2.12 2.122zM16.24 6.344l2.122-2.122 1.414 1.414-2.122 2.122zM6.342 7.759 4.22 5.637l1.415-1.414 2.12 2.122zm13.434 10.605-1.414 1.414-2.122-2.122 1.414-1.414z" />
                  </svg>
                </button>
              )
            }
          </li>
        </ul>
      </nav>
    </div>
  </div>
</header>

<style>
  #skip-to-content {
    @apply absolute -top-full left-16 z-50 bg-skin-accent px-3 py-2 text-white transition-all focus:top-4;
  }
  .header-container {
    @apply sticky top-0 z-50 w-full border-b border-skin-line bg-skin-fill/80 backdrop-blur-lg;
  }
  .header-inner {
    @apply mx-auto flex max-w-5xl items-center justify-between px-6 py-4;
  }
  .logo {
    @apply text-xl font-bold tracking-tight no-underline sm:text-2xl;
  }
  .logo-r {
    color: rgb(var(--color-text-base));
    font-weight: 700;
  }
  .logo-t {
    color: rgb(var(--color-accent));
    font-weight: 800;
  }
  .hamburger-menu {
    @apply p-2 sm:hidden;
  }
  .hamburger-menu svg {
    @apply h-6 w-6 scale-125 fill-skin-base;
  }
  nav {
    @apply flex flex-col items-center sm:flex-row sm:gap-1;
  }
  nav ul {
    @apply mt-4 flex w-full flex-col gap-1 sm:mt-0 sm:w-auto sm:flex-row sm:items-center sm:gap-1;
  }
  nav ul li {
    @apply flex items-center justify-center;
  }
  nav ul li a {
    @apply rounded-lg px-3 py-2 text-sm font-medium text-skin-base/70 transition-colors hover:bg-skin-card-muted hover:text-skin-base sm:px-3 sm:py-1.5;
  }
  nav .active {
    @apply bg-skin-card-muted text-skin-accent;
  }
  nav button {
    @apply p-1;
  }
  nav button svg {
    @apply h-5 w-5 fill-skin-base hover:fill-skin-accent;
  }
  #theme-btn {
    @apply flex items-center justify-center rounded-lg p-2 transition-colors hover:bg-skin-card-muted;
  }
  .theme-icon {
    @apply !h-[18px] !w-[18px] fill-skin-base transition-transform hover:rotate-12;
  }
  .menu-icon line {
    @apply transition-opacity duration-75 ease-in-out;
  }
  .menu-icon .close {
    opacity: 0;
  }
  .menu-icon.is-active .line {
    @apply opacity-0;
  }
  .menu-icon.is-active .close {
    @apply opacity-100;
  }
  .nav-icon-item {
    @apply flex;
  }
</style>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector(".hamburger-menu");
    const menuIcon = document.querySelector(".menu-icon");
    const menuItems = document.querySelector("#menu-items");

    menuBtn?.addEventListener("click", () => {
      const menuExpanded = menuBtn.getAttribute("aria-expanded") === "true";
      menuIcon?.classList.toggle("is-active");
      menuBtn.setAttribute("aria-expanded", menuExpanded ? "false" : "true");
      menuBtn.setAttribute("aria-label", menuExpanded ? "Open Menu" : "Close Menu");
      menuItems?.classList.toggle("display-none");
    });
  }

  toggleNav();
  document.addEventListener("astro:after-swap", toggleNav);
</script>
