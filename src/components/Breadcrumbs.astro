---
import { getLocaleFromUrl } from "../i18n/utils";
import translations from "../i18n/translations";

const locale = getLocaleFromUrl(Astro.url);
const t = translations[locale].breadcrumb;

let currentUrlPath = Astro.url.pathname.replace(/\/+$/, "");
if (locale === "es") {
  currentUrlPath = currentUrlPath.replace(/^\/es/, "");
}
const breadcrumbList = currentUrlPath.split("/").slice(1);
const prefix = locale === "es" ? "/es" : "";
---

<nav class="site-container breadcrumb" aria-label="breadcrumb">
  <ul>
    <li>
      <a href={`${prefix}/`}>{t.home}</a>
      <span class="crumb-sep" aria-hidden="true">/</span>
    </li>
    {
      breadcrumbList.map((breadcrumb, index) =>
        index + 1 === breadcrumbList.length ? (
          <li>
            <span
              class={`${index > 0 ? "lowercase" : "capitalize"}`}
              aria-current="page"
            >
              {decodeURIComponent(breadcrumb)}
            </span>
          </li>
        ) : (
          <li>
            <a href={`${prefix}/${breadcrumb}/`}>{breadcrumb}</a>
            <span class="crumb-sep" aria-hidden="true">/</span>
          </li>
        )
      )
    }
  </ul>
</nav>

<style>
  .breadcrumb {
    @apply mb-2 mt-6 text-xs;
  }
  .breadcrumb ul li {
    @apply inline;
  }
  .breadcrumb ul li a {
    @apply capitalize text-skin-base/40 hover:text-skin-accent;
  }
  .breadcrumb ul li span {
    @apply text-skin-base/40;
  }
  .crumb-sep {
    @apply px-1.5 text-skin-base/20;
  }
</style>
