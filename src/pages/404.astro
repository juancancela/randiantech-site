---
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
---

<Layout title={`404 Not Found | ${SITE.title}`}>
  <Header />

  <main id="main-content">
    <div class="not-found-wrapper">
      <div class="text-8xl font-bold text-skin-accent sm:text-9xl">404</div>
      <p class="mt-4 text-xl text-skin-base/60 sm:text-2xl">Page not found</p>
      <a href="/" class="btn-outline mt-8">
        Go back home &rarr;
      </a>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  #main-content {
    @apply mx-auto flex max-w-5xl flex-1 items-center justify-center px-6;
  }
  .not-found-wrapper {
    @apply mb-14 flex flex-col items-center justify-center text-center;
  }
</style>
