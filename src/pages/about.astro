---
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
---

<Layout title={`About | ${SITE.title}`}>
  <Header activeNav="about" />
  <Breadcrumbs />
  <main id="main-content" class="relative">
    <canvas id="circuit-about" data-circuit-bg class="pointer-events-none absolute inset-0 -z-10 h-full w-full opacity-40" aria-hidden="true"></canvas>

    <section class="site-container pt-8 pb-20 sm:pb-32">
      <div data-animate>
        <div class="section-label mb-3">About</div>
        <h1 class="text-3xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
          Engineering impact through <span class="gradient-text">intelligent solutions</span>
        </h1>
        <p class="mt-6 max-w-3xl text-lg text-skin-base/70 leading-relaxed">
          Randiantech is a technology consulting company specializing in AI integration, enterprise training, and software engineering. We help companies navigate the AI landscape and build production-ready solutions that deliver real business value.
        </p>
      </div>
    </section>

    <section class="site-container pb-20 sm:pb-32">
      <div class="section-label mb-8" data-animate>Our journey</div>
      <div class="relative">
        <div class="timeline-line"></div>
        <div class="grid gap-12 sm:gap-16">
          <div class="timeline-item" data-animate data-animate-delay="100">
            <div class="timeline-year">2016</div>
            <div class="timeline-content">
              <h3 class="text-xl font-bold">Founded in Buenos Aires</h3>
              <p class="mt-2 text-sm text-skin-base/60 leading-relaxed">Started as a small team of engineers passionate about building great software. Focused on staff augmentation for US-based companies, working in their timezones with senior-level talent.</p>
            </div>
          </div>
          <div class="timeline-item" data-animate data-animate-delay="200">
            <div class="timeline-year">2018</div>
            <div class="timeline-content">
              <h3 class="text-xl font-bold">Regional expansion</h3>
              <p class="mt-2 text-sm text-skin-base/60 leading-relaxed">Expanded operations to Honduras and Miami. Built deep expertise in fintech, healthtech, and e-commerce through partnerships with companies like GoFundMe and the Financial Times.</p>
            </div>
          </div>
          <div class="timeline-item" data-animate data-animate-delay="300">
            <div class="timeline-year">2023</div>
            <div class="timeline-content">
              <h3 class="text-xl font-bold">AI-first pivot</h3>
              <p class="mt-2 text-sm text-skin-base/60 leading-relaxed">Recognized the transformative potential of AI early. Shifted focus to AI consulting, enterprise training, and building AI-powered products. Became a go-to partner for companies integrating LLMs, RAG, and agent architectures.</p>
            </div>
          </div>
          <div class="timeline-item" data-animate data-animate-delay="400">
            <div class="timeline-year">Today</div>
            <div class="timeline-content">
              <h3 class="text-xl font-bold">AI consulting & engineering</h3>
              <p class="mt-2 text-sm text-skin-base/60 leading-relaxed">A team of 15+ engineers, architects, and technical leaders delivering AI training, staff augmentation, and custom AI products to companies across the Americas.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="site-container pb-20 sm:pb-32">
      <div data-animate>
        <div class="section-label mb-3">What sets us apart</div>
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Our philosophy</h2>
      </div>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="card" data-animate data-animate-delay="100">
          <div class="diff-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/></svg>
          </div>
          <h3 class="mt-4 text-base font-semibold">Pragmatic engineering</h3>
          <p class="mt-2 text-sm text-skin-base/60">We choose the right tools for the job, not the trendiest. Every solution is built for production from day one.</p>
        </div>
        <div class="card" data-animate data-animate-delay="200">
          <div class="diff-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h3 class="mt-4 text-base font-semibold">Zero distance to clients</h3>
          <p class="mt-2 text-sm text-skin-base/60">All engineers work on US timezones. We integrate into your team, your workflow, your Slack. No offshore friction.</p>
        </div>
        <div class="card" data-animate data-animate-delay="300">
          <div class="diff-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
          </div>
          <h3 class="mt-4 text-base font-semibold">AI-native mindset</h3>
          <p class="mt-2 text-sm text-skin-base/60">We don't just build AI features—we think AI-first. Every project starts with "how can AI make this better?"</p>
        </div>
        <div class="card" data-animate data-animate-delay="400">
          <div class="diff-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="mt-4 text-base font-semibold">Senior-only talent</h3>
          <p class="mt-2 text-sm text-skin-base/60">No juniors learning on your dime. Every engineer we place has 5+ years of production experience.</p>
        </div>
        <div class="card" data-animate data-animate-delay="500">
          <div class="diff-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M7 7h10"/><path d="M7 12h10"/><path d="M7 17h10"/></svg>
          </div>
          <h3 class="mt-4 text-base font-semibold">Business outcomes first</h3>
          <p class="mt-2 text-sm text-skin-base/60">We measure success by impact, not by lines of code. Every engagement is tied to concrete business goals.</p>
        </div>
        <div class="card" data-animate data-animate-delay="600">
          <div class="diff-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7h-3a2 2 0 0 1-2-2V2"/><path d="M9 18a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h7l4 4v10a2 2 0 0 1-2 2Z"/><path d="M3 7.6v12.8A1.6 1.6 0 0 0 4.6 22h9.8"/></svg>
          </div>
          <h3 class="mt-4 text-base font-semibold">Deep industry expertise</h3>
          <p class="mt-2 text-sm text-skin-base/60">Fintech, healthtech, e-commerce, media—we've built production systems in all of them.</p>
        </div>
      </div>
    </section>

    <section class="site-container pb-20 sm:pb-32" data-animate>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div class="stat-card">
          <div class="text-3xl font-bold text-skin-accent">15+</div>
          <div class="mt-1 text-sm text-skin-base/60">Engineers & architects</div>
        </div>
        <div class="stat-card">
          <div class="text-3xl font-bold text-skin-accent">50+</div>
          <div class="mt-1 text-sm text-skin-base/60">Projects delivered</div>
        </div>
        <div class="stat-card">
          <div class="text-3xl font-bold text-skin-accent">3</div>
          <div class="mt-1 text-sm text-skin-base/60">Countries</div>
        </div>
        <div class="stat-card">
          <div class="text-3xl font-bold text-skin-accent">8+</div>
          <div class="mt-1 text-sm text-skin-base/60">Years in business</div>
        </div>
      </div>
    </section>

    <section class="site-container pb-20 sm:pb-32">
      <div data-animate>
        <div class="section-label mb-3">Our stack</div>
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Technologies we master</h2>
      </div>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-animate data-animate-delay="200">
        <div class="card-flat rounded-xl border border-skin-line p-5">
          <div class="text-sm font-semibold text-skin-accent">Languages</div>
          <p class="mt-2 text-sm text-skin-base/60">TypeScript, Kotlin, Python, Go</p>
        </div>
        <div class="card-flat rounded-xl border border-skin-line p-5">
          <div class="text-sm font-semibold text-skin-accent">Backend</div>
          <p class="mt-2 text-sm text-skin-base/60">Node.js, Spring Boot, FastAPI, .NET</p>
        </div>
        <div class="card-flat rounded-xl border border-skin-line p-5">
          <div class="text-sm font-semibold text-skin-accent">Frontend</div>
          <p class="mt-2 text-sm text-skin-base/60">React, Next.js, Astro</p>
        </div>
        <div class="card-flat rounded-xl border border-skin-line p-5">
          <div class="text-sm font-semibold text-skin-accent">Cloud & DevOps</div>
          <p class="mt-2 text-sm text-skin-base/60">AWS, GCP, Azure, Docker, Kubernetes, Terraform</p>
        </div>
        <div class="card-flat rounded-xl border border-skin-line p-5">
          <div class="text-sm font-semibold text-skin-accent">Data</div>
          <p class="mt-2 text-sm text-skin-base/60">PostgreSQL, MongoDB, Redis, Kafka</p>
        </div>
        <div class="card-flat rounded-xl border border-skin-line p-5">
          <div class="text-sm font-semibold text-skin-accent">AI / ML</div>
          <p class="mt-2 text-sm text-skin-base/60">OpenAI, Anthropic, LangChain, RAG, custom agents</p>
        </div>
      </div>
    </section>

    <section class="site-container pb-20 sm:pb-32" data-animate>
      <div class="relative overflow-hidden rounded-2xl bg-skin-card-muted p-10 text-center sm:p-16">
        <h2 class="text-2xl font-bold tracking-tight sm:text-4xl">Let's work together</h2>
        <p class="mx-auto mt-4 max-w-xl text-base text-skin-base/60">
          Whether you need AI training for your team, expert engineers to scale your product, or a custom AI solution built from scratch — we'd love to hear from you.
        </p>
        <div class="mt-8">
          <a href="/contact/" class="btn-primary">Get in touch &rarr;</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .timeline-line {
    @apply absolute left-6 top-0 bottom-0 w-0 border-l border-skin-line sm:left-8;
  }
  .timeline-item {
    @apply relative flex gap-6 pl-14 sm:pl-20;
  }
  .timeline-year {
    @apply absolute left-0 top-0 flex h-12 w-12 items-center justify-center rounded-full border border-skin-line bg-skin-card text-xs font-bold text-skin-accent sm:h-16 sm:w-16 sm:text-sm;
  }
  .timeline-content {
    @apply pt-2;
  }
  .diff-icon {
    @apply flex h-10 w-10 items-center justify-center rounded-lg bg-skin-accent/10;
  }
  .diff-icon svg {
    @apply h-5 w-5 stroke-skin-accent fill-none;
  }
  .stat-card {
    @apply rounded-xl border border-skin-line bg-skin-card p-6 text-center;
  }
</style>
