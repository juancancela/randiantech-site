---
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const leadership = [
  {
    name: "Juan Carlos Cancela",
    position: "CEO & Co-founder",
    desc: "Motivated, action-oriented technology enthusiast with experience on multiple industries designing cutting-edge Web API-centric applications.",
    url: "http://juancancela.work/",
  },
  {
    name: "Guillermo Ismael Mulvihill",
    position: "COO & Co-founder",
    desc: "Extremely hard worker and technology lover with vast experience in leadership and team management as well as in the world of finances and investments.",
    url: "https://www.linkedin.com/in/guillermo-ismael-mulvihill-965384b8/",
  },
];

const staff = [
  {
    name: "Malcolm Mancuso",
    position: "Full Stack Developer",
    desc: "Tech Stack: React, Javascript, NodeJS, MongoDB, Heroku.",
    url: "https://www.linkedin.com/in/malcolm-ezequiel-mancuso-400b42192/",
  },
  {
    name: "Lucas Campana",
    position: "Full Stack Developer",
    desc: "Tech Stack: Python, React, Javascript, NodeJS, ExpressJS, MongoDB, Java.",
    url: "https://www.linkedin.com/in/lukebelll/",
  },
  {
    name: "Nancy Figueroa",
    position: "Full Stack Developer",
    desc: "Tech Stack: ReactJS, NodeJS, ExpressJS, MongoDB. GraphQL using Apollo Server and Apollo Client.",
    url: "https://www.linkedin.com/in/nancy-figueroa-0a763725/",
  },
  {
    name: "Leonardo Palumbo",
    position: "Backend Developer",
    desc: "Tech Stack: .NET, C#, Web API, Web Services, Java.",
    url: "https://www.linkedin.com/in/leonardo-dar%C3%ADo-palumbo-93a56b178/",
  },
  {
    name: "Martin Ruffa",
    position: "Backend Developer",
    desc: "Tech Stack: .NET, C#, Web API, Web Services, Java, MVC, HTML5, CSS3, Javascript, jQuery.",
    url: "https://www.linkedin.com/in/martin-ruffa-5188b676/",
  },
  {
    name: "Leandro Jodor",
    position: "Frontend Developer",
    desc: "Tech Stack: ReactJS, Javascript, NodeJS, ExpressJS, MongoDB.",
    url: "https://www.linkedin.com/in/leandro-martin-jodor-211859119/",
  },
  {
    name: "Esteban Pistoia",
    position: "QA Automation Engineer",
    desc: "Tech Stack: Selenium Webdriver with Java, Cypress, WebdriverIO.",
    url: "https://www.linkedin.com/in/esteban-francisco-pistoia-01080a168/",
  },
  {
    name: "Florencia Jodor",
    position: "QA Automation Engineer",
    desc: "Tech Stack: Cypress, WebdriverIO.",
    url: "https://www.linkedin.com/in/maria-florencia-jodor-2a25151a2/",
  },
  {
    name: "Laura Palumbo",
    position: "QA Analyst",
    desc: "Tech Stack: Functional testing, Non functional (Jmeter), SQL, HTML, CSS.",
    url: "https://www.linkedin.com/in/laura-palumbo-4986351a8/",
  },
  {
    name: "Pablo Carnelli",
    position: "QA Analyst",
    desc: "Tech Stack: Functional testing, API testing (Postman, SoapUI), SQL, HTML, CSS.",
    url: "https://www.linkedin.com/in/pablo-carnelli-12333812/",
  },
];

function getInitials(name: string): string {
  return name.split(" ").map(n => n[0]).join("").slice(0, 2).toUpperCase();
}
---

<Layout title={`Team | ${SITE.title}`}>
  <Header activeNav="team" />
  <Breadcrumbs />
  <main id="main-content">
    <section class="site-container mb-16 mt-6">
      <div class="press-frame press-surface-white w-full p-6 sm:p-8">
        <h1 class="text-2xl tracking-wider sm:text-3xl">Meet the RT Team</h1>

        <h2 class="section-label">Leadership</h2>
        <div class="team-grid leadership-grid">
          {leadership.map((member) => (
            <a
              href={member.url}
              target="_blank"
              rel="noopener noreferrer"
              class="member-card press-frame-subtle press-surface-paper p-5"
            >
              <div class="avatar">{getInitials(member.name)}</div>
              <div class="font-mono text-sm font-semibold">{member.name}</div>
              <div class="font-mono text-xs text-skin-accent">{member.position}</div>
              <div class="mt-2 font-serif text-sm leading-relaxed opacity-80">
                {member.desc}
              </div>
            </a>
          ))}
        </div>

        <h2 class="section-label">Team</h2>
        <div class="team-grid staff-grid">
          {staff.map((member) => (
            <a
              href={member.url}
              target="_blank"
              rel="noopener noreferrer"
              class="member-card press-frame-subtle press-surface-paper p-4"
            >
              <div class="avatar avatar-sm">{getInitials(member.name)}</div>
              <div class="font-mono text-sm font-semibold">{member.name}</div>
              <div class="font-mono text-xs text-skin-accent">{member.position}</div>
              <div class="mt-1 font-serif text-xs leading-relaxed opacity-70">
                {member.desc}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .section-label {
    @apply mt-8 mb-4 font-mono text-lg font-semibold tracking-wide;
  }

  .team-grid {
    display: grid;
    gap: 1rem;
  }

  .leadership-grid {
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }

  .staff-grid {
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }

  @media (min-width: 640px) {
    .leadership-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .staff-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .member-card {
    @apply block no-underline text-skin-base transition-transform hover:scale-[1.02];
  }

  .avatar {
    @apply mb-3 flex h-16 w-16 items-center justify-center font-mono text-lg font-bold;
    background: rgb(var(--color-accent));
    color: rgb(var(--color-fill));
  }

  .avatar-sm {
    @apply h-12 w-12 text-sm;
  }
</style>
