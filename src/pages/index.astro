---
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { SITE } from "@config";
import translations from "../i18n/translations";

const t = translations.en.home;

const clientLogos = [
  { name: "Capgemini", url: "https://www.capgemini.com/" },
  { name: "INTI", url: "https://www.argentina.gob.ar/inti" },
  { name: "Chekku", url: "https://www.chekku.co/" },
] as const;

const techStack = [
  "TypeScript",
  "Python",
  "Kotlin",
  "Go",
  "React",
  "Next.js",
  "Node.js",
  "Spring Boot",
  "FastAPI",
  "AWS",
  "GCP",
  "Docker",
  "Kubernetes",
  "PostgreSQL",
  "MongoDB",
  "Redis",
  "Kafka",
  "OpenAI",
  "LangChain",
  "Terraform",
] as const;
---

<Layout title={SITE.title} description={SITE.desc}>
  <Header />
  <main id="main-content">
    <section
      id="hero"
      class="hero-section relative w-full overflow-hidden border-b border-skin-line/60 bg-skin-fill pt-28 pb-24 sm:pt-40 sm:pb-32 lg:pb-40"
    >
      <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
        <div class="hero-glow hero-glow--tl"></div>
        <div class="hero-glow hero-glow--br"></div>
      </div>

      <div class="relative mx-auto flex max-w-6xl flex-col gap-16 px-4 lg:grid lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:items-center lg:gap-12">
        <div class="max-w-2xl lg:max-w-none" data-animate>
          <div class="section-label mb-5">{t.label}</div>
          <h1
            class="text-4xl font-bold leading-[1.08] tracking-tight sm:text-6xl lg:text-7xl"
          >
            {t.title}
            <span class="gradient-text">{t.titleAccent}</span>
          </h1>
          <p class="mt-8 max-w-xl text-lg leading-relaxed text-skin-base/70 sm:text-xl">
            {t.desc}
          </p>
          <div class="mt-12 flex flex-wrap gap-4">
            <a href="/contact/" class="btn-primary">{t.cta} &rarr;</a>
            <a href="/services/" class="btn-outline">{t.ctaSecondary}</a>
          </div>
        </div>

        <div
          class="globe-wrapper relative mx-auto aspect-square w-full max-w-md lg:mx-0 lg:max-w-none"
          data-animate
          data-animate-delay="120"
        >
          <canvas id="hero-globe" class="h-full w-full"></canvas>
        </div>
      </div>
    </section>

    <section id="services" class="relative !max-w-6xl py-24 sm:py-36">
      <div
        class="pointer-events-none absolute right-0 top-24 -z-10 h-72 w-72 translate-x-1/3 rounded-full opacity-40 blur-3xl"
        style="background: radial-gradient(circle, rgba(var(--color-accent), 0.12) 0%, transparent 70%);"
        aria-hidden="true"
      ></div>

      <div class="relative mx-auto max-w-6xl">
        <div class="max-w-3xl" data-animate>
          <div class="section-label mb-4">{t.servicesLabel}</div>
          <h2 class="text-3xl font-bold tracking-tight sm:text-5xl">
            {t.servicesTitle}
          </h2>
          <p class="mt-6 max-w-2xl text-lg leading-relaxed text-skin-base/70">
            {t.servicesDesc}
          </p>
        </div>

        <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3 lg:gap-10">
          <div class="card group relative overflow-hidden" data-animate data-animate-delay="100">
            <div
              class="pointer-events-none absolute -right-12 -top-12 h-32 w-32 rounded-full opacity-30 blur-2xl"
              style="background: radial-gradient(circle, rgba(var(--color-accent), 0.25) 0%, transparent 70%);"
              aria-hidden="true"
            ></div>
            <div class="card-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M12 6V2H8"></path><path
                  d="m8 18-4 4V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2Z"
                ></path><path d="M2 12h2"></path><path d="M9 11v2"></path><path d="M15 11v2"
                ></path><path d="M20 12h2"></path></svg
              >
            </div>
            <h3 class="mt-6 text-xl font-semibold">{t.service1Title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-skin-base/60">{t.service1Desc}</p>
            <a href="/services/" class="mt-6 inline-block text-xs font-medium text-skin-accent">
              {t.serviceLearnMore} &rarr;
            </a>
          </div>

          <div class="card group relative overflow-hidden" data-animate data-animate-delay="200">
            <div
              class="pointer-events-none absolute -right-12 -top-12 h-32 w-32 rounded-full opacity-30 blur-2xl"
              style="background: radial-gradient(circle, rgba(var(--color-accent), 0.25) 0%, transparent 70%);"
              aria-hidden="true"
            ></div>
            <div class="card-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle
                  cx="9"
                  cy="7"
                  r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path
                  d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg
              >
            </div>
            <h3 class="mt-6 text-xl font-semibold">{t.service2Title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-skin-base/60">{t.service2Desc}</p>
            <a href="/services/" class="mt-6 inline-block text-xs font-medium text-skin-accent">
              {t.serviceLearnMore} &rarr;
            </a>
          </div>

          <div class="card group relative overflow-hidden" data-animate data-animate-delay="300">
            <div
              class="pointer-events-none absolute -right-12 -top-12 h-32 w-32 rounded-full opacity-30 blur-2xl"
              style="background: radial-gradient(circle, rgba(var(--color-accent), 0.25) 0%, transparent 70%);"
              aria-hidden="true"
            ></div>
            <div class="card-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"
                ></path></svg
              >
            </div>
            <h3 class="mt-6 text-xl font-semibold">{t.service3Title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-skin-base/60">{t.service3Desc}</p>
            <a href="/services/" class="mt-6 inline-block text-xs font-medium text-skin-accent">
              {t.serviceLearnMore} &rarr;
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="proof" class="relative !max-w-6xl py-24 sm:py-36">
      <div class="relative mx-auto max-w-6xl">
        <div
          class="pointer-events-none absolute inset-x-0 -top-px mx-auto h-px max-w-md bg-gradient-to-r from-transparent via-skin-accent/40 to-transparent"
          aria-hidden="true"
        ></div>
        <div class="grid gap-6 sm:grid-cols-3 sm:gap-8">
          <div
            class="card-flat cursor-default border border-skin-line bg-skin-card px-6 py-10 text-center sm:px-8"
            data-animate
            data-animate-delay="100"
          >
            <div class="text-5xl font-bold tabular-nums text-skin-accent sm:text-6xl">2016</div>
            <div class="mt-3 text-sm font-medium text-skin-base/60">{t.proofFounded}</div>
          </div>
          <div
            class="card-flat cursor-default border border-skin-line bg-skin-card px-6 py-10 text-center sm:px-8"
            data-animate
            data-animate-delay="200"
          >
            <div class="text-5xl font-bold tabular-nums text-skin-accent sm:text-6xl">50+</div>
            <div class="mt-3 text-sm font-medium text-skin-base/60">{t.proofProjects}</div>
          </div>
          <div
            class="card-flat cursor-default border border-skin-line bg-skin-card px-6 py-10 text-center sm:px-8"
            data-animate
            data-animate-delay="300"
          >
            <div class="text-4xl font-bold tracking-tight text-skin-accent sm:text-5xl">US/LATAM</div>
            <div class="mt-3 text-sm font-medium text-skin-base/60">{t.proofPresence}</div>
          </div>
        </div>
      </div>
    </section>

    <section id="clients" class="!max-w-6xl py-24 sm:py-36">
      <div class="relative mx-auto max-w-6xl">
        <div class="max-w-3xl" data-animate>
          <div class="section-label mb-4">{t.clientsLabel}</div>
          <h2 class="text-3xl font-bold tracking-tight sm:text-5xl">{t.clientsTitle}</h2>
        </div>
        <div
          class="mt-14 flex flex-wrap items-center justify-start gap-x-14 gap-y-10 sm:gap-x-16 sm:gap-y-12"
        >
          {
            clientLogos.map((company, i) => (
              <a
                href={company.url}
                target="_blank"
                rel="noopener noreferrer"
                class="cursor-pointer text-lg font-semibold tracking-tight text-skin-base/35 no-underline transition-colors hover:text-skin-base/65 sm:text-xl"
                data-animate
                data-animate-delay={String((i + 1) * 100)}
              >
                {company.name}
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section id="tech" class="relative !max-w-6xl py-24 sm:py-36">
      <div
        class="pointer-events-none absolute bottom-0 left-0 -z-10 h-64 w-64 -translate-x-1/2 translate-y-1/4 rounded-full opacity-50 blur-3xl"
        style="background: radial-gradient(circle, rgba(var(--color-accent), 0.1) 0%, transparent 70%);"
        aria-hidden="true"
      ></div>

      <div class="relative mx-auto max-w-6xl">
        <div class="max-w-3xl" data-animate>
          <div class="section-label mb-4">{t.techLabel}</div>
          <h2 class="text-3xl font-bold tracking-tight sm:text-5xl">{t.techTitle}</h2>
        </div>
        <div class="mt-14 flex flex-wrap gap-3 sm:gap-4" data-animate data-animate-delay="150">
          {
            techStack.map((tech) => (
              <span class="tech-chip">{tech}</span>
            ))
          }
        </div>
      </div>
    </section>

    <section id="cta" class="!max-w-6xl pb-28 sm:pb-36">
      <div class="relative mx-auto max-w-6xl" data-animate>
        <div
          class="card-flat relative overflow-hidden rounded-3xl border border-skin-line bg-skin-card-muted px-8 py-16 text-center sm:px-16 sm:py-20"
        >
          <svg
            class="pointer-events-none absolute -left-4 top-0 h-40 w-40 text-skin-accent/20 sm:h-52 sm:w-52"
            viewBox="0 0 200 200"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <circle cx="36" cy="36" r="64" stroke="currentColor" stroke-width="1.5" opacity="0.5"
            ></circle>
            <circle cx="56" cy="56" r="40" stroke="currentColor" stroke-width="1" opacity="0.35"></circle>
          </svg>
          <svg
            class="pointer-events-none absolute -bottom-6 -right-6 h-48 w-48 text-skin-accent/15 sm:h-64 sm:w-64"
            viewBox="0 0 200 200"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path
              d="M120 180c44 0 80-36 80-80S164 20 120 20"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              opacity="0.6"></path>
            <path
              d="M140 160c33 0 60-27 60-60s-27-60-60-60"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              opacity="0.4"></path>
          </svg>
          <div class="cta-glow"></div>
          <h2 class="relative text-2xl font-bold tracking-tight sm:text-4xl lg:text-[2.5rem]">
            {t.ctaBottomTitle}
          </h2>
          <p class="relative mx-auto mt-5 max-w-2xl text-base leading-relaxed text-skin-base/60 sm:text-lg">
            {t.ctaBottomDesc}
          </p>
          <div class="relative mt-10">
            <a href="/contact/" class="btn-primary">{t.ctaBottomBtn} &rarr;</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .hero-section {
    max-width: 100% !important;
  }

  .globe-wrapper {
    min-height: 320px;
  }
  @media (min-width: 1024px) {
    .globe-wrapper {
      min-height: 440px;
    }
  }

  .card-icon {
    @apply relative z-[1] flex h-14 w-14 items-center justify-center rounded-xl bg-skin-accent/10;
  }
  .card-icon svg {
    @apply h-7 w-7 stroke-skin-accent fill-none;
  }

  .tech-chip {
    @apply rounded-xl border border-skin-line bg-skin-card px-5 py-2.5 text-sm font-medium text-skin-base/70 transition-colors duration-200 hover:border-skin-accent hover:text-skin-accent;
  }

  .hero-glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }
  .hero-glow--tl {
    top: -140px;
    left: -100px;
    width: 420px;
    height: 420px;
    background: radial-gradient(circle, rgba(var(--color-accent), 0.14) 0%, transparent 68%);
  }
  .hero-glow--br {
    bottom: -160px;
    right: -120px;
    width: 520px;
    height: 520px;
    background: radial-gradient(circle, rgba(var(--color-accent), 0.1) 0%, transparent 70%);
  }
  .cta-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: min(100%, 480px);
    height: min(100%, 480px);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(var(--color-accent), 0.08) 0%, transparent 72%);
    pointer-events: none;
  }
</style>
