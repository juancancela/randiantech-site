---
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
import { SITE } from "@config";
---

<Layout title={SITE.title} description={SITE.desc}>
  <Header />
  <main id="main-content">
    <section id="hero" class="pb-6 pt-8">
      <div class="press-frame press-surface-white overflow-hidden p-6 sm:p-8">
        <div class="w-full">
          <h1 class="font-semibold tracking-tight">
            Your partner to craft <span class="text-skin-accent">superb</span> software.
          </h1>

          <div class="mt-4 space-y-4 text-base leading-relaxed font-serif">
            <p>
              Founded by experienced IT professionals, <strong>Randian Tech</strong>
              embodies a comprehensive approach on how to successfully architect,
              implement and deliver mission-critical products and services.
            </p>
            <p>
              From early-stage MVPs to complex distributed architectures, we
              bring deep technical expertise and a pragmatic approach to every
              engagement. Our team has shipped production systems for companies
              across fintech, healthtech, e-commerce, and media.
            </p>
            <p>
              We specialize in <strong>Web APIs</strong>,
              <strong>cloud-native architectures</strong>,
              <strong>AI integration</strong>, and
              <strong>product delivery</strong> — always with a focus on
              outcomes over output.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section id="services" class="pb-6 pt-6">
      <h2>Our Services</h2>
      <div class="services-grid">
        <a href="/services/" class="press-frame-subtle press-surface-paper p-5 service-card">
          <img src="/images/services/tg-staff-augmentation.svg" alt="Staff Augmentation" class="service-icon" />
          <div class="font-mono text-xs uppercase tracking-wider opacity-80">
            Staff Augmentation
          </div>
          <div class="mt-2 font-serif text-sm leading-relaxed">
            Extend your team with skilled engineers who integrate seamlessly into your workflow.
          </div>
        </a>
        <a href="/services/" class="press-frame-subtle press-surface-paper p-5 service-card">
          <img src="/images/services/tg-fixed-price-project.svg" alt="Fixed Price Projects" class="service-icon" />
          <div class="font-mono text-xs uppercase tracking-wider opacity-80">
            Fixed Price Projects
          </div>
          <div class="mt-2 font-serif text-sm leading-relaxed">
            End-to-end development with clear scope, timeline, and budget — from discovery to delivery.
          </div>
        </a>
        <a href="/services/" class="press-frame-subtle press-surface-paper p-5 service-card">
          <img src="/images/services/tg-managed-agile-teams.svg" alt="Managed Agile Teams" class="service-icon" />
          <div class="font-mono text-xs uppercase tracking-wider opacity-80">
            Managed Agile Teams
          </div>
          <div class="mt-2 font-serif text-sm leading-relaxed">
            Fully-managed, autonomous development squads delivering iteratively with full transparency.
          </div>
        </a>
        <a href="/services/" class="press-frame-subtle press-surface-paper p-5 service-card">
          <img src="/images/services/tg-on-site-training.svg" alt="On Site Training" class="service-icon" />
          <div class="font-mono text-xs uppercase tracking-wider opacity-80">
            On Site Training
          </div>
          <div class="mt-2 font-serif text-sm leading-relaxed">
            Technical mentors providing architectural guidelines and hands-on training for your teams.
          </div>
        </a>
      </div>
    </section>

    <section id="technologies" class="pb-6 pt-6">
      <h2>Technologies</h2>
      <div class="tech-grid">
        <div class="press-frame-subtle press-surface-paper p-4 text-center">
          <div class="font-mono text-xs font-semibold">TypeScript</div>
        </div>
        <div class="press-frame-subtle press-surface-paper p-4 text-center">
          <div class="font-mono text-xs font-semibold">Kotlin</div>
        </div>
        <div class="press-frame-subtle press-surface-paper p-4 text-center">
          <div class="font-mono text-xs font-semibold">Python</div>
        </div>
        <div class="press-frame-subtle press-surface-paper p-4 text-center">
          <div class="font-mono text-xs font-semibold">Go</div>
        </div>
        <div class="press-frame-subtle press-surface-paper p-4 text-center">
          <div class="font-mono text-xs font-semibold">React</div>
        </div>
        <div class="press-frame-subtle press-surface-paper p-4 text-center">
          <div class="font-mono text-xs font-semibold">Node.js</div>
        </div>
        <div class="press-frame-subtle press-surface-paper p-4 text-center">
          <div class="font-mono text-xs font-semibold">Spring Boot</div>
        </div>
        <div class="press-frame-subtle press-surface-paper p-4 text-center">
          <div class="font-mono text-xs font-semibold">FastAPI</div>
        </div>
        <div class="press-frame-subtle press-surface-paper p-4 text-center">
          <div class="font-mono text-xs font-semibold">AWS</div>
        </div>
        <div class="press-frame-subtle press-surface-paper p-4 text-center">
          <div class="font-mono text-xs font-semibold">Docker</div>
        </div>
        <div class="press-frame-subtle press-surface-paper p-4 text-center">
          <div class="font-mono text-xs font-semibold">Kubernetes</div>
        </div>
        <div class="press-frame-subtle press-surface-paper p-4 text-center">
          <div class="font-mono text-xs font-semibold">PostgreSQL</div>
        </div>
        <div class="press-frame-subtle press-surface-paper p-4 text-center">
          <div class="font-mono text-xs font-semibold">MongoDB</div>
        </div>
        <div class="press-frame-subtle press-surface-paper p-4 text-center">
          <div class="font-mono text-xs font-semibold">Redis</div>
        </div>
        <div class="press-frame-subtle press-surface-paper p-4 text-center">
          <div class="font-mono text-xs font-semibold">Kafka</div>
        </div>
        <div class="press-frame-subtle press-surface-paper p-4 text-center">
          <div class="font-mono text-xs font-semibold">OpenAI</div>
        </div>
        <div class="press-frame-subtle press-surface-paper p-4 text-center">
          <div class="font-mono text-xs font-semibold">LangChain</div>
        </div>
        <div class="press-frame-subtle press-surface-paper p-4 text-center">
          <div class="font-mono text-xs font-semibold">Terraform</div>
        </div>
      </div>
    </section>

    <section id="cta" class="pb-12 pt-6">
      <div class="press-frame press-surface-white p-6 text-center sm:p-8">
        <h2 class="text-xl font-semibold sm:text-2xl">Let's craft it together.</h2>
        <p class="mt-2 font-serif text-base opacity-80">
          Ready to build something great? Let's talk about your project.
        </p>
        <div class="mt-6">
          <LinkButton
            href="/contact/"
            className="inline-block border-2 border-skin-accent bg-skin-accent px-6 py-3 font-semibold text-white hover:opacity-85"
          >
            Get in touch &rarr;
          </LinkButton>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  #hero h1 {
    @apply my-4 inline-block text-3xl font-bold sm:my-8 sm:text-5xl;
  }

  #services h2,
  #technologies h2 {
    @apply text-2xl font-semibold tracking-wide;
  }

  .services-grid {
    @apply mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2;
  }

  .service-card {
    @apply block no-underline text-skin-base transition-transform hover:scale-[1.02];
  }

  .service-icon {
    @apply mb-3 h-16 w-16 opacity-80;
  }

  .tech-grid {
    @apply mt-4 grid grid-cols-3 gap-3 sm:grid-cols-6;
  }
</style>
