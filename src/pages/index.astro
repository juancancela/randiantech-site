---
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
import { SITE } from "@config";
---

<Layout title={SITE.title} description={SITE.desc}>
  <Header />
  <main id="main-content">
    <section id="hero" class="pb-6 pt-8">
      <div class="press-frame press-surface-white overflow-hidden p-6 sm:p-8">
        <div class="w-full">
          <h1 class="font-semibold tracking-tight">
            We build software that works.
          </h1>

          <div class="mt-4 space-y-4 text-base leading-relaxed font-serif">
            <p>
              <strong>Randian Tech</strong> is a software engineering company
              focused on building reliable, scalable, and maintainable systems.
              We partner with startups and established companies to deliver
              products that solve real problems.
            </p>
            <p>
              From early-stage MVPs to complex distributed architectures, we
              bring deep technical expertise and a pragmatic approach to every
              engagement. Our team has shipped production systems for companies
              across fintech, healthtech, e-commerce, and media.
            </p>
            <p>
              We specialize in <strong>Web APIs</strong>,
              <strong>cloud-native architectures</strong>,
              <strong>AI integration</strong>, and
              <strong>product delivery</strong> — always with a focus on
              outcomes over output.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section id="services" class="pb-6 pt-6">
      <h2>What we do</h2>
      <div class="services-grid">
        <div class="press-frame-subtle press-surface-paper p-5">
          <div class="font-mono text-xs uppercase tracking-wider opacity-80">
            Product Engineering
          </div>
          <div class="mt-2 font-serif text-sm leading-relaxed">
            End-to-end development of web applications and APIs. From discovery
            to production, we own the full lifecycle.
          </div>
        </div>
        <div class="press-frame-subtle press-surface-paper p-5">
          <div class="font-mono text-xs uppercase tracking-wider opacity-80">
            AI & LLM Integration
          </div>
          <div class="mt-2 font-serif text-sm leading-relaxed">
            Practical AI integration into existing products — from prompt
            engineering and RAG pipelines to custom agent workflows.
          </div>
        </div>
        <div class="press-frame-subtle press-surface-paper p-5">
          <div class="font-mono text-xs uppercase tracking-wider opacity-80">
            Cloud & Infrastructure
          </div>
          <div class="mt-2 font-serif text-sm leading-relaxed">
            Cloud-native architectures on AWS, GCP, or Azure. CI/CD pipelines,
            observability, and infrastructure as code.
          </div>
        </div>
        <div class="press-frame-subtle press-surface-paper p-5">
          <div class="font-mono text-xs uppercase tracking-wider opacity-80">
            Technical Leadership
          </div>
          <div class="mt-2 font-serif text-sm leading-relaxed">
            Fractional CTO and tech lead services. Architecture reviews, team
            mentoring, and engineering strategy.
          </div>
        </div>
      </div>
    </section>

    <section id="cta" class="pb-12 pt-6">
      <div class="press-frame press-surface-white p-6 text-center sm:p-8">
        <h2 class="text-xl font-semibold sm:text-2xl">Ready to build?</h2>
        <p class="mt-2 font-serif text-base opacity-80">
          Let's talk about your project and how we can help.
        </p>
        <div class="mt-6">
          <LinkButton
            href="/contact/"
            className="inline-block border-2 border-skin-accent bg-skin-accent px-6 py-3 font-semibold text-white hover:opacity-85"
          >
            Get in touch &rarr;
          </LinkButton>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  #hero h1 {
    @apply my-4 inline-block text-3xl font-bold sm:my-8 sm:text-5xl;
  }

  #services h2 {
    @apply text-2xl font-semibold tracking-wide;
  }

  .services-grid {
    @apply mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2;
  }
</style>
