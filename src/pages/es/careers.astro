---
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import translations from "../../i18n/translations";

const t = translations.es.careers;

const positions = [
  { title: "FullStack Developer", desc: "React, Javascript, NodeJS, MongoDB, Heroku." },
  { title: "Frontend Developer", desc: "React, TypeScript, Next.js, CSS moderno." },
  { title: "Backend Developer", desc: "Node.js, Python, GraphQL, REST APIs, microservicios." },
  { title: "QA Automation Engineer", desc: "Selenium, Cypress, WebdriverIO, integración CI/CD." },
  { title: "QA Manual", desc: "Testing funcional, no funcional, SQL, API testing." },
  { title: "AI/ML Engineer", desc: "Integración LLM, pipelines RAG, arquitecturas de agentes, Python." },
];
---

<Layout title={`${t.label} | ${SITE.title}`}>
  <Header activeNav="careers" />
  <Breadcrumbs />
  <main id="main-content">
    <section class="site-container pt-6 pb-16">
      <div class="section-label mb-3">{t.label}</div>
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{t.title}</h1>
      <p class="mt-4 max-w-2xl text-base text-skin-base/70">{t.desc}</p>

      <h2 class="mt-12 mb-6 text-xl font-bold tracking-tight">{t.openPositions}</h2>
      <div class="grid gap-3 sm:grid-cols-2">
        {positions.map((position) => (
          <a href={`mailto:info@randiantech.com?subject=Me interesa la posición de ${position.title}`} class="card group">
            <div class="text-base font-semibold group-hover:text-skin-accent transition-colors">{position.title}</div>
            <p class="mt-2 text-sm text-skin-base/60">{position.desc}</p>
            <div class="mt-3 text-xs font-medium text-skin-accent">{t.apply} &rarr;</div>
          </a>
        ))}
      </div>

      <div class="mt-16 rounded-2xl bg-skin-card-muted p-8 text-center sm:p-12">
        <h2 class="text-2xl font-bold tracking-tight">{t.noRoleTitle}</h2>
        <p class="mx-auto mt-3 max-w-xl text-base text-skin-base/60">{t.noRoleDesc}</p>
        <div class="mt-6">
          <a href="mailto:info@randiantech.com?subject=Me interesa sumarme al equipo!" class="btn-primary">{t.noRoleBtn} &rarr;</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
