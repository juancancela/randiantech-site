---
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import translations from "../../i18n/translations";

const t = translations.es.careers;

const positions = [
  {
    title: "Ingeniero IA",
    type: "Full-time · Remoto",
    summary: "Construí sistemas IA productivos — integraciones LLM, pipelines RAG y arquitecturas de agentes.",
    description: `Buscamos un Ingeniero IA para diseñar y construir sistemas IA listos para producción para nuestros clientes. Vas a trabajar en integraciones LLM, pipelines RAG, arquitecturas de agentes autónomos y automatización inteligente.

**Lo que vas a hacer:**
- Diseñar e implementar features potenciados por LLM (chat, resúmenes, clasificación, generación)
- Construir sistemas RAG con bases de datos vectoriales (Pinecone, Weaviate, pgvector)
- Desarrollar flujos de agentes multi-paso usando LangChain, CrewAI o frameworks custom
- Evaluar y fine-tunear modelos para casos de uso específicos
- Colaborar con equipos de ingeniería de clientes para integrar IA en productos existentes

**Lo que buscamos:**
- 3+ años de experiencia en ingeniería de software
- 1+ año de experiencia práctica con LLMs e IA/ML en producción
- Sólidas habilidades en Python; TypeScript es un plus
- Experiencia con APIs de OpenAI, Anthropic o similares
- Familiaridad con bases de datos vectoriales y modelos de embeddings
- Entendimiento sólido de prompt engineering y estrategias de retrieval`,
  },
  {
    title: "Desarrollador Full-Stack",
    type: "Full-time · Remoto",
    summary: "Desarrollo de productos end-to-end con React, Node.js, TypeScript y Python.",
    description: `Estamos contratando un Desarrollador Full-Stack para unirse a equipos de clientes y construir aplicaciones web modernas de punta a punta. Vas a trabajar en productos greenfield y codebases maduros, con foco en calidad, performance y experiencia de desarrollo.

**Lo que vas a hacer:**
- Construir y mantener aplicaciones web full-stack (React, Next.js, Node.js)
- Diseñar e implementar APIs REST y GraphQL
- Trabajar de cerca con equipos de producto y diseño en sprints ágiles
- Escribir tests, participar en code reviews y mentorear desarrolladores junior
- Contribuir a decisiones de arquitectura y roadmaps técnicos

**Lo que buscamos:**
- 5+ años de experiencia profesional en desarrollo full-stack
- Nivel experto en TypeScript y React
- Sólidas habilidades de backend (Node.js, Express, NestJS o similar)
- Experiencia con bases de datos relacionales y NoSQL
- Cómodo trabajando en horarios US con equipos angloparlantes
- Experiencia en CI/CD, Docker y plataformas cloud (AWS o GCP)`,
  },
  {
    title: "Ingeniero de Datos",
    type: "Full-time · Remoto",
    summary: "Diseñá pipelines de datos, construí procesos ETL y habilitá infraestructura de datos lista para IA.",
    description: `Necesitamos un Ingeniero de Datos para ayudar a nuestros clientes a construir infraestructura de datos robusta que potencie analytics y sistemas IA. Vas a diseñar pipelines, gestionar data warehouses y asegurar calidad de datos a escala.

**Lo que vas a hacer:**
- Diseñar y construir pipelines ETL/ELT escalables
- Gestionar data warehouses (Snowflake, BigQuery, Redshift)
- Construir pipelines de datos en streaming con Kafka, Kinesis o similares
- Implementar monitoreo y validación de calidad de datos
- Colaborar con ingenieros IA para preparar datos de entrenamiento y feature stores

**Lo que buscamos:**
- 4+ años de experiencia en ingeniería de datos
- Sólidas habilidades en SQL y Python
- Experiencia con Apache Spark, dbt o Airflow
- Familiaridad con plataformas de datos cloud (AWS, GCP o Azure)
- Entendimiento de modelado de datos y diseño de warehouses
- Experiencia con arquitecturas de streaming es un plus`,
  },
  {
    title: "Ingeniero QA Automation",
    type: "Full-time · Remoto",
    summary: "Construí frameworks de automatización de tests y asegurá la calidad del producto en todo el stack.",
    description: `Buscamos un Ingeniero QA Automation para construir y mantener frameworks de automatización de tests en nuestros proyectos de clientes. Vas a asegurar calidad en plataformas web, API y mobile.

**Lo que vas a hacer:**
- Diseñar e implementar estrategias de automatización de tests
- Construir suites de tests E2E con Cypress, Playwright o Selenium
- Crear suites de tests de API con Postman, REST Assured o similares
- Integrar tests en pipelines CI/CD
- Realizar tests de performance y carga cuando sea necesario
- Colaborar con desarrolladores para mejorar la testeabilidad y calidad

**Lo que buscamos:**
- 4+ años de experiencia en QA con fuerte enfoque en automatización
- Experto en al menos un framework de testing moderno (Cypress, Playwright, Selenium)
- Sólidas habilidades de programación (JavaScript/TypeScript o Java)
- Experiencia con integración CI/CD (GitHub Actions, Jenkins)
- Experiencia en testing de APIs y testing de performance
- Excelente atención al detalle y habilidades de comunicación`,
  },
  {
    title: "Ingeniero DevOps / Cloud",
    type: "Full-time · Remoto",
    summary: "Construí y gestioná infraestructura cloud, pipelines CI/CD y automatización de despliegues.",
    description: `Estamos contratando un Ingeniero DevOps/Cloud para ayudar a nuestros clientes a construir infraestructura confiable y escalable. Vas a trabajar en arquitectura cloud, CI/CD, containerización y monitoreo.

**Lo que vas a hacer:**
- Diseñar y gestionar infraestructura cloud en AWS, GCP o Azure
- Construir y mantener pipelines CI/CD (GitHub Actions, GitLab CI, Jenkins)
- Containerizar aplicaciones con Docker y orquestar con Kubernetes
- Implementar infraestructura como código con Terraform o Pulumi
- Configurar monitoreo, alertas y observabilidad (Datadog, Grafana, CloudWatch)
- Asegurar buenas prácticas de seguridad y compliance

**Lo que buscamos:**
- 4+ años de experiencia en ingeniería DevOps/Cloud
- Sólida experiencia con al menos un proveedor cloud principal
- Experto en Docker y Kubernetes
- Experiencia en infraestructura como código (Terraform preferido)
- Habilidades de scripting (Bash, Python)
- Entendimiento de networking, seguridad y optimización de costos`,
  },
];
---

<Layout title={`${t.label} | ${SITE.title}`}>
  <Header activeNav="careers" />
  <Breadcrumbs />
  <main id="main-content">
    <section class="site-container pt-6 pb-16">
      <div data-animate>
        <div class="section-label mb-3">{t.label}</div>
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{t.title}</h1>
        <p class="mt-4 max-w-2xl text-base text-skin-base/70">{t.desc}</p>
      </div>

      <h2 class="mt-12 mb-6 text-xl font-bold tracking-tight" data-animate>{t.openPositions}</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {positions.map((pos, i) => (
          <button
            class="card group text-left cursor-pointer job-card"
            data-job={JSON.stringify({ title: pos.title, type: pos.type, description: pos.description })}
            data-animate
            data-animate-delay={String((i + 1) * 100)}
          >
            <div class="text-base font-semibold group-hover:text-skin-accent transition-colors">{pos.title}</div>
            <div class="mt-1 text-xs text-skin-accent">{pos.type}</div>
            <p class="mt-3 text-sm text-skin-base/60">{pos.summary}</p>
            <div class="mt-4 text-xs font-medium text-skin-accent">Ver detalles &rarr;</div>
          </button>
        ))}
      </div>

      <div class="mt-16 rounded-2xl bg-skin-card-muted p-8 text-center sm:p-12" data-animate>
        <h2 class="text-2xl font-bold tracking-tight">{t.noRoleTitle}</h2>
        <p class="mx-auto mt-3 max-w-xl text-base text-skin-base/60">{t.noRoleDesc}</p>
        <div class="mt-6">
          <button id="open-apply-btn" class="btn-primary">{t.noRoleBtn} &rarr;</button>
        </div>
      </div>
    </section>

    <!-- Job Details Modal -->
    <div id="job-modal" class="modal-overlay hidden" role="dialog" aria-modal="true">
  <div class="modal-container">
    <div class="modal-header">
      <div>
        <h2 id="modal-title" class="text-xl font-bold"></h2>
        <p id="modal-type" class="mt-1 text-sm text-skin-accent"></p>
      </div>
      <button id="modal-close" class="modal-close-btn" aria-label="Cerrar">&times;</button>
    </div>
    <div id="modal-body" class="modal-body prose max-w-none"></div>
    <div id="modal-apply-section" class="modal-footer">
      <div id="apply-form-wrapper">
        <p class="text-sm font-medium mb-3">Aplicar a esta posición</p>
        <div class="flex gap-3">
          <input type="url" id="modal-linkedin" placeholder="Tu URL de LinkedIn" class="form-input flex-1" />
          <button id="modal-apply-btn" class="btn-primary whitespace-nowrap">Aplicar &rarr;</button>
        </div>
        <p id="modal-apply-status" class="mt-3 text-sm hidden"></p>
      </div>
    </div>
  </div>
</div>

    <!-- General Apply Modal (¿No ves tu rol?) -->
    <div id="general-modal" class="modal-overlay hidden" role="dialog" aria-modal="true">
      <div class="modal-container">
        <div class="modal-header">
          <h2 class="text-xl font-bold">Sumate al equipo</h2>
          <button id="general-modal-close" class="modal-close-btn" aria-label="Cerrar">&times;</button>
        </div>
        <div class="modal-body">
          <p class="text-sm text-skin-base/70">Mandanos tu perfil de LinkedIn y nos comunicamos si hay un match.</p>
        </div>
        <div class="modal-footer">
          <div class="flex gap-3">
            <input type="url" id="general-linkedin" placeholder="Tu URL de LinkedIn" class="form-input flex-1" />
            <button id="general-apply-btn" class="btn-primary whitespace-nowrap">Enviar &rarr;</button>
          </div>
          <p id="general-apply-status" class="mt-3 text-sm hidden"></p>
        </div>
      </div>
    </div>

  </main>
  <Footer />
</Layout>

<style>
  .form-input {
    @apply w-full rounded-lg border border-skin-line bg-skin-card px-4 py-2.5 text-sm text-skin-base outline-none transition-colors placeholder:text-skin-base/30 focus:border-skin-accent;
  }
  .modal-overlay {
    @apply fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm p-4;
  }
  .modal-container {
    @apply w-full max-w-2xl max-h-[85vh] overflow-hidden rounded-2xl border border-skin-line bg-skin-fill shadow-2xl flex flex-col;
  }
  .modal-header {
    @apply flex items-start justify-between p-6 border-b border-skin-line;
  }
  .modal-close-btn {
    @apply text-2xl text-skin-base/40 hover:text-skin-base transition-colors leading-none;
  }
  .modal-body {
    @apply p-6 overflow-y-auto flex-1;
  }
  .modal-footer {
    @apply p-6 border-t border-skin-line;
  }
</style>

<script is:inline>
  (function() {
    function initCareers() {
      var jobModal = document.getElementById("job-modal");
      var generalModal = document.getElementById("general-modal");
      var modalTitle = document.getElementById("modal-title");
      var modalType = document.getElementById("modal-type");
      var modalBody = document.getElementById("modal-body");
      if (!jobModal || !generalModal) return;

      jobModal.classList.add("hidden");
      generalModal.classList.add("hidden");
      document.body.style.overflow = "";

      function openModal(modal) {
        modal.classList.remove("hidden");
        document.body.style.overflow = "hidden";
      }
      function closeModal(modal) {
        modal.classList.add("hidden");
        document.body.style.overflow = "";
      }

      function markdownToHtml(md) {
        return md
          .replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>")
          .replace(/^- (.+)$/gm, "<li>$1</li>")
          .replace(/\n\n/g, "</p><p>")
          .replace(/\n/g, "<br>");
      }

      document.querySelectorAll(".job-card").forEach(function(card) {
        card.onclick = function() {
          var data = JSON.parse(card.dataset.job || "{}");
          if (modalTitle) modalTitle.textContent = data.title;
          if (modalType) modalType.textContent = data.type;
          if (modalBody) modalBody.innerHTML = "<p>" + markdownToHtml(data.description || "") + "</p>";
          var li = document.getElementById("modal-linkedin");
          if (li) li.value = "";
          var st = document.getElementById("modal-apply-status");
          if (st) st.classList.add("hidden");
          openModal(jobModal);
        };
      });

      var closeBtn = document.getElementById("modal-close");
      if (closeBtn) closeBtn.onclick = function() { closeModal(jobModal); };

      var genCloseBtn = document.getElementById("general-modal-close");
      if (genCloseBtn) genCloseBtn.onclick = function() { closeModal(generalModal); };

      jobModal.onclick = function(e) { if (e.target === jobModal) closeModal(jobModal); };
      generalModal.onclick = function(e) { if (e.target === generalModal) closeModal(generalModal); };

      var openApplyBtn = document.getElementById("open-apply-btn");
      if (openApplyBtn) {
        openApplyBtn.onclick = function() {
          var li = document.getElementById("general-linkedin");
          if (li) li.value = "";
          var st = document.getElementById("general-apply-status");
          if (st) st.classList.add("hidden");
          openModal(generalModal);
        };
      }

      function submitApplication(role, linkedinInput, statusEl, btn) {
        var url = linkedinInput.value.trim();
        if (!url || url.indexOf("linkedin.com") === -1) {
          statusEl.textContent = "Por favor ingres\u00e1 una URL de LinkedIn v\u00e1lida";
          statusEl.className = "mt-3 text-sm text-red-500";
          return;
        }
        btn.disabled = true;
        btn.textContent = "Enviando...";
        fetch("/api/apply", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ role: role, linkedinUrl: url }),
        }).then(function(res) {
          if (res.ok) {
            statusEl.textContent = "\u00a1Aplicaci\u00f3n enviada! Nos pondremos en contacto pronto.";
            statusEl.className = "mt-3 text-sm text-green-600";
            linkedinInput.value = "";
          } else {
            throw new Error("Failed");
          }
        }).catch(function() {
          statusEl.textContent = "Algo sali\u00f3 mal. Por favor intent\u00e1 de nuevo.";
          statusEl.className = "mt-3 text-sm text-red-500";
        }).finally(function() {
          btn.disabled = false;
          btn.textContent = "Aplicar \u2192";
        });
      }

      var applyBtn = document.getElementById("modal-apply-btn");
      if (applyBtn) {
        applyBtn.onclick = function() {
          submitApplication(
            (modalTitle && modalTitle.textContent) || "Desconocido",
            document.getElementById("modal-linkedin"),
            document.getElementById("modal-apply-status"),
            applyBtn
          );
        };
      }

      var genApplyBtn = document.getElementById("general-apply-btn");
      if (genApplyBtn) {
        genApplyBtn.onclick = function() {
          submitApplication(
            "Aplicaci\u00f3n general",
            document.getElementById("general-linkedin"),
            document.getElementById("general-apply-status"),
            genApplyBtn
          );
        };
      }

      document.addEventListener("keydown", function(e) {
        if (e.key === "Escape") {
          closeModal(jobModal);
          closeModal(generalModal);
        }
      });
    }

    initCareers();
    document.addEventListener("astro:after-swap", initCareers);
  })();
</script>
