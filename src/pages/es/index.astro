---
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { SITE } from "@config";
import translations from "../../i18n/translations";

const t = translations.es.home;

const clientLogos = [
  "GoFundMe",
  "Financial Times",
  "Capgemini",
  "Globant",
  "Level 3 Communications",
] as const;

const techStack = [
  "TypeScript",
  "Python",
  "Kotlin",
  "Go",
  "React",
  "Next.js",
  "Node.js",
  "Spring Boot",
  "FastAPI",
  "AWS",
  "GCP",
  "Docker",
  "Kubernetes",
  "PostgreSQL",
  "MongoDB",
  "Redis",
  "Kafka",
  "OpenAI",
  "LangChain",
  "Terraform",
] as const;
---

<Layout title={SITE.title} description={SITE.desc}>
  <Header />
  <main id="main-content">
    <!-- Shared gradient defs for decorative SVGs -->
    <svg
      class="pointer-events-none absolute h-0 w-0 overflow-hidden"
      aria-hidden="true"
      focusable="false"
    >
      <defs>
        <linearGradient id="home-grad-accent" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" class="home-grad-stop-a"></stop>
          <stop offset="55%" class="home-grad-stop-b"></stop>
          <stop offset="100%" class="home-grad-stop-c"></stop>
        </linearGradient>
        <linearGradient id="home-grad-soft" x1="100%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" class="home-grad-stop-soft-a"></stop>
          <stop offset="100%" class="home-grad-stop-soft-b"></stop>
        </linearGradient>
        <radialGradient id="home-grad-orb" cx="50%" cy="50%" r="50%">
          <stop offset="0%" class="home-grad-orb-a"></stop>
          <stop offset="70%" class="home-grad-orb-b"></stop>
        </radialGradient>
      </defs>
    </svg>

    <section
      id="hero"
      class="relative !max-w-6xl overflow-hidden border-b border-skin-line/60 bg-skin-fill pt-28 pb-24 sm:pt-40 sm:pb-32 lg:pb-40"
    >
      <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
        <div class="hero-glow hero-glow--tl"></div>
        <div class="hero-glow hero-glow--br"></div>
        <svg
          class="home-mesh absolute left-1/2 top-0 h-[min(90vh,720px)] w-[min(140vw,900px)] -translate-x-1/2 opacity-[0.35] dark:opacity-[0.22]"
          viewBox="0 0 800 800"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path
            d="M0 80h800M0 160h800M0 240h800M0 320h800M0 400h800M0 480h800M0 560h800M0 640h800M0 720h800M80 0v800M160 0v800M240 0v800M320 0v800M400 0v800M480 0v800M560 0v800M640 0v800M720 0v800"
            class="home-mesh-line"></path>
        </svg>
      </div>

      <div class="relative mx-auto flex max-w-6xl flex-col gap-16 lg:grid lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:items-center lg:gap-20">
        <div class="max-w-2xl lg:max-w-none" data-animate>
          <div class="section-label mb-5">{t.label}</div>
          <h1
            class="text-4xl font-bold leading-[1.08] tracking-tight sm:text-6xl lg:text-7xl"
          >
            {t.title}
            <span class="gradient-text">{t.titleAccent}</span>
          </h1>
          <p class="mt-8 max-w-xl text-lg leading-relaxed text-skin-base/70 sm:text-xl">
            {t.desc}
          </p>
          <div class="mt-12 flex flex-wrap gap-4">
            <a href="/es/contact/" class="btn-primary">{t.cta} &rarr;</a>
            <a href="/es/services/" class="btn-outline">{t.ctaSecondary}</a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-lg lg:mx-0 lg:max-w-none"
          data-animate
          data-animate-delay="120"
        >
          <div
            class="pointer-events-none absolute -right-8 -top-8 h-48 w-48 rounded-full bg-skin-accent/15 blur-3xl"
            aria-hidden="true"
          ></div>
          <div
            class="pointer-events-none absolute -bottom-10 -left-6 h-40 w-40 rounded-full bg-skin-accent/10 blur-3xl"
            aria-hidden="true"
          ></div>
          <svg
            class="home-hero-illu relative w-full drop-shadow-sm"
            viewBox="0 0 480 420"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <rect
              x="48"
              y="56"
              width="384"
              height="280"
              rx="28"
              class="home-illu-frame"></rect>
            <rect
              x="72"
              y="88"
              width="148"
              height="96"
              rx="12"
              fill="url(#home-grad-soft)"
              opacity="0.9"></rect>
            <rect
              x="236"
              y="88"
              width="172"
              height="44"
              rx="10"
              class="home-illu-bar"></rect>
            <rect
              x="236"
              y="148"
              width="132"
              height="36"
              rx="8"
              class="home-illu-bar-muted"></rect>
            <rect
              x="236"
              y="196"
              width="172"
              height="36"
              rx="8"
              class="home-illu-bar-muted"></rect>
            <circle cx="120" cy="248" r="36" fill="url(#home-grad-orb)" opacity="0.85"></circle>
            <path
              d="M156 248h52l32 28h72"
              class="home-illu-wire"></path>
            <circle cx="312" cy="276" r="14" fill="url(#home-grad-accent)" opacity="0.9"></circle>
            <circle cx="380" cy="248" r="10" class="home-illu-node"></circle>
            <circle cx="340" cy="200" r="8" class="home-illu-node-soft"></circle>
            <circle cx="268" cy="312" r="8" class="home-illu-node-soft"></circle>
            <path
              d="M380 248l-40 28M340 200l-28 76M268 312l44-36"
              class="home-illu-wire-thin"></path>
            <rect
              x="72"
              y="208"
              width="96"
              height="12"
              rx="4"
              class="home-illu-pill"></rect>
            <rect
              x="72"
              y="232"
              width="72"
              height="12"
              rx="4"
              class="home-illu-pill-muted"></rect>
          </svg>
        </div>
      </div>
    </section>

    <section id="services" class="relative !max-w-6xl py-24 sm:py-36">
      <div
        class="pointer-events-none absolute right-0 top-24 -z-10 h-72 w-72 translate-x-1/3 rounded-full opacity-40 blur-3xl"
        style="background: radial-gradient(circle, rgba(var(--color-accent), 0.12) 0%, transparent 70%);"
        aria-hidden="true"
      ></div>

      <div class="relative mx-auto max-w-6xl">
        <div class="max-w-3xl" data-animate>
          <div class="section-label mb-4">{t.servicesLabel}</div>
          <h2 class="text-3xl font-bold tracking-tight sm:text-5xl">
            {t.servicesTitle}
          </h2>
          <p class="mt-6 max-w-2xl text-lg leading-relaxed text-skin-base/70">
            {t.servicesDesc}
          </p>
        </div>

        <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3 lg:gap-10">
          <div class="card group relative overflow-hidden" data-animate data-animate-delay="100">
            <div
              class="pointer-events-none absolute -right-12 -top-12 h-32 w-32 rounded-full opacity-30 blur-2xl"
              style="background: radial-gradient(circle, rgba(var(--color-accent), 0.25) 0%, transparent 70%);"
              aria-hidden="true"
            ></div>
            <div class="card-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M12 6V2H8"></path><path
                  d="m8 18-4 4V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2Z"
                ></path><path d="M2 12h2"></path><path d="M9 11v2"></path><path d="M15 11v2"
                ></path><path d="M20 12h2"></path></svg
              >
            </div>
            <h3 class="mt-6 text-xl font-semibold">{t.service1Title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-skin-base/60">{t.service1Desc}</p>
            <a href="/es/services/" class="mt-6 inline-block text-xs font-medium text-skin-accent">
              {t.serviceLearnMore} &rarr;
            </a>
          </div>

          <div class="card group relative overflow-hidden" data-animate data-animate-delay="200">
            <div
              class="pointer-events-none absolute -right-12 -top-12 h-32 w-32 rounded-full opacity-30 blur-2xl"
              style="background: radial-gradient(circle, rgba(var(--color-accent), 0.25) 0%, transparent 70%);"
              aria-hidden="true"
            ></div>
            <div class="card-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle
                  cx="9"
                  cy="7"
                  r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path
                  d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg
              >
            </div>
            <h3 class="mt-6 text-xl font-semibold">{t.service2Title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-skin-base/60">{t.service2Desc}</p>
            <a href="/es/services/" class="mt-6 inline-block text-xs font-medium text-skin-accent">
              {t.serviceLearnMore} &rarr;
            </a>
          </div>

          <div class="card group relative overflow-hidden" data-animate data-animate-delay="300">
            <div
              class="pointer-events-none absolute -right-12 -top-12 h-32 w-32 rounded-full opacity-30 blur-2xl"
              style="background: radial-gradient(circle, rgba(var(--color-accent), 0.25) 0%, transparent 70%);"
              aria-hidden="true"
            ></div>
            <div class="card-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"
                ></path></svg
              >
            </div>
            <h3 class="mt-6 text-xl font-semibold">{t.service3Title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-skin-base/60">{t.service3Desc}</p>
            <a href="/es/services/" class="mt-6 inline-block text-xs font-medium text-skin-accent">
              {t.serviceLearnMore} &rarr;
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="proof" class="relative !max-w-6xl py-24 sm:py-36">
      <div class="relative mx-auto max-w-6xl">
        <div
          class="pointer-events-none absolute inset-x-0 -top-px mx-auto h-px max-w-md bg-gradient-to-r from-transparent via-skin-accent/40 to-transparent"
          aria-hidden="true"
        ></div>
        <div class="grid gap-6 sm:grid-cols-3 sm:gap-8">
          <div
            class="card-flat border border-skin-line bg-skin-card px-8 py-10 text-center"
            data-animate
            data-animate-delay="100"
          >
            <div class="text-5xl font-bold tabular-nums text-skin-accent sm:text-6xl">2016</div>
            <div class="mt-3 text-sm font-medium text-skin-base/60">{t.proofFounded}</div>
          </div>
          <div
            class="card-flat border border-skin-line bg-skin-card px-8 py-10 text-center"
            data-animate
            data-animate-delay="200"
          >
            <div class="text-5xl font-bold tabular-nums text-skin-accent sm:text-6xl">50+</div>
            <div class="mt-3 text-sm font-medium text-skin-base/60">{t.proofProjects}</div>
          </div>
          <div
            class="card-flat border border-skin-line bg-skin-card px-8 py-10 text-center"
            data-animate
            data-animate-delay="300"
          >
            <div class="text-5xl font-bold tabular-nums text-skin-accent sm:text-6xl">US/LATAM</div>
            <div class="mt-3 text-sm font-medium text-skin-base/60">{t.proofPresence}</div>
          </div>
        </div>
      </div>
    </section>

    <section id="clients" class="!max-w-6xl py-24 sm:py-36">
      <div class="relative mx-auto max-w-6xl">
        <div class="max-w-3xl" data-animate>
          <div class="section-label mb-4">{t.clientsLabel}</div>
          <h2 class="text-3xl font-bold tracking-tight sm:text-5xl">{t.clientsTitle}</h2>
        </div>
        <div
          class="mt-14 flex flex-wrap items-center justify-start gap-x-14 gap-y-10 sm:gap-x-16 sm:gap-y-12"
        >
          {
            clientLogos.map((company, i) => (
              <div
                class="text-lg font-semibold tracking-tight text-skin-base/35 transition-colors hover:text-skin-base/65 sm:text-xl"
                data-animate
                data-animate-delay={String((i + 1) * 100)}
              >
                {company}
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section id="tech" class="relative !max-w-6xl py-24 sm:py-36">
      <div
        class="pointer-events-none absolute bottom-0 left-0 -z-10 h-64 w-64 -translate-x-1/2 translate-y-1/4 rounded-full opacity-50 blur-3xl"
        style="background: radial-gradient(circle, rgba(var(--color-accent), 0.1) 0%, transparent 70%);"
        aria-hidden="true"
      ></div>

      <div class="relative mx-auto max-w-6xl">
        <div class="max-w-3xl" data-animate>
          <div class="section-label mb-4">{t.techLabel}</div>
          <h2 class="text-3xl font-bold tracking-tight sm:text-5xl">{t.techTitle}</h2>
        </div>
        <div class="mt-14 flex flex-wrap gap-3 sm:gap-4" data-animate data-animate-delay="150">
          {
            techStack.map((tech) => (
              <span class="tech-chip">{tech}</span>
            ))
          }
        </div>
      </div>
    </section>

    <section id="cta" class="!max-w-6xl pb-28 sm:pb-36">
      <div class="relative mx-auto max-w-6xl" data-animate>
        <div
          class="card-flat relative overflow-hidden rounded-3xl border border-skin-line bg-skin-card-muted px-8 py-16 text-center sm:px-16 sm:py-20"
        >
          <svg
            class="pointer-events-none absolute -left-4 top-0 h-40 w-40 text-skin-accent/20 sm:h-52 sm:w-52"
            viewBox="0 0 200 200"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <circle cx="36" cy="36" r="64" stroke="url(#home-grad-accent)" stroke-width="1.5" opacity="0.5"
            ></circle>
            <circle cx="56" cy="56" r="40" stroke="currentColor" stroke-width="1" opacity="0.35"></circle>
          </svg>
          <svg
            class="pointer-events-none absolute -bottom-6 -right-6 h-48 w-48 text-skin-accent/15 sm:h-64 sm:w-64"
            viewBox="0 0 200 200"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path
              d="M120 180c44 0 80-36 80-80S164 20 120 20"
              stroke="url(#home-grad-accent)"
              stroke-width="2"
              stroke-linecap="round"
              opacity="0.6"></path>
            <path
              d="M140 160c33 0 60-27 60-60s-27-60-60-60"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              opacity="0.4"></path>
          </svg>
          <div class="cta-glow"></div>
          <h2 class="relative text-2xl font-bold tracking-tight sm:text-4xl lg:text-[2.5rem]">
            {t.ctaBottomTitle}
          </h2>
          <p class="relative mx-auto mt-5 max-w-2xl text-base leading-relaxed text-skin-base/60 sm:text-lg">
            {t.ctaBottomDesc}
          </p>
          <div class="relative mt-10">
            <a href="/es/contact/" class="btn-primary">{t.ctaBottomBtn} &rarr;</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .home-grad-stop-a {
    stop-color: rgb(var(--color-accent));
    stop-opacity: 0.85;
  }
  .home-grad-stop-b {
    stop-color: rgb(var(--color-accent));
    stop-opacity: 0.35;
  }
  .home-grad-stop-c {
    stop-color: rgb(var(--color-text-base));
    stop-opacity: 0.08;
  }
  .home-grad-stop-soft-a {
    stop-color: rgb(var(--color-accent));
    stop-opacity: 0.2;
  }
  .home-grad-stop-soft-b {
    stop-color: rgb(var(--color-accent));
    stop-opacity: 0.05;
  }
  .home-grad-orb-a {
    stop-color: rgb(var(--color-accent));
    stop-opacity: 0.45;
  }
  .home-grad-orb-b {
    stop-color: rgb(var(--color-accent));
    stop-opacity: 0;
  }
  .home-mesh-line {
    stroke: rgb(var(--color-border));
    stroke-width: 1;
  }
  .home-illu-frame {
    stroke: rgb(var(--color-border));
    stroke-width: 1.5;
    fill: rgb(var(--color-card));
    fill-opacity: 0.55;
  }
  :global(html[data-theme="dark"]) .home-illu-frame {
    fill-opacity: 0.35;
  }
  .home-illu-bar {
    fill: rgb(var(--color-accent));
    fill-opacity: 0.12;
    stroke: rgb(var(--color-accent));
    stroke-opacity: 0.25;
    stroke-width: 1;
  }
  .home-illu-bar-muted {
    fill: rgb(var(--color-text-base));
    fill-opacity: 0.04;
    stroke: rgb(var(--color-border));
    stroke-width: 1;
  }
  .home-illu-wire {
    stroke: rgb(var(--color-accent));
    stroke-opacity: 0.35;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .home-illu-wire-thin {
    stroke: rgb(var(--color-accent));
    stroke-opacity: 0.25;
    stroke-width: 1.5;
    stroke-linecap: round;
  }
  .home-illu-node {
    fill: rgb(var(--color-accent));
    fill-opacity: 0.55;
    stroke: rgb(var(--color-card));
    stroke-width: 2;
  }
  .home-illu-node-soft {
    fill: rgb(var(--color-accent));
    fill-opacity: 0.2;
    stroke: rgb(var(--color-border));
    stroke-width: 1;
  }
  .home-illu-pill {
    fill: rgb(var(--color-text-base));
    fill-opacity: 0.06;
  }
  .home-illu-pill-muted {
    fill: rgb(var(--color-text-base));
    fill-opacity: 0.04;
  }
  .home-hero-illu {
    display: block;
    height: auto;
    width: 100%;
    max-width: 32rem;
  }

  .card-icon {
    @apply relative z-[1] flex h-14 w-14 items-center justify-center rounded-xl bg-skin-accent/10;
  }
  .card-icon svg {
    @apply h-7 w-7 stroke-skin-accent fill-none;
  }

  .tech-chip {
    @apply rounded-xl border border-skin-line bg-skin-card px-5 py-2.5 text-sm font-medium text-skin-base/70 transition-colors duration-200 hover:border-skin-accent hover:text-skin-accent;
  }

  .hero-glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }
  .hero-glow--tl {
    top: -140px;
    left: -100px;
    width: 420px;
    height: 420px;
    background: radial-gradient(circle, rgba(var(--color-accent), 0.14) 0%, transparent 68%);
  }
  .hero-glow--br {
    bottom: -160px;
    right: -120px;
    width: 520px;
    height: 520px;
    background: radial-gradient(circle, rgba(var(--color-accent), 0.1) 0%, transparent 70%);
  }
  .cta-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: min(100%, 480px);
    height: min(100%, 480px);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(var(--color-accent), 0.08) 0%, transparent 72%);
    pointer-events: none;
  }
</style>
