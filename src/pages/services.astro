---
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import translations from "../i18n/translations";

const t = translations.en.services;
---

<Layout title={`${t.label} | ${SITE.title}`}>
  <Header activeNav="services" />
  <Breadcrumbs />
  <main id="main-content" class="relative">
    <canvas id="circuit-services-page" data-circuit-bg class="pointer-events-none absolute inset-0 -z-10 h-full w-full opacity-40" aria-hidden="true"></canvas>
    <section class="site-container pt-6 pb-16">
      <div data-animate>
        <div class="section-label mb-3">{t.label}</div>
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{t.title}</h1>
        <p class="mt-4 max-w-2xl text-base text-skin-base/70">{t.desc}</p>
      </div>

      <div class="mt-12 space-y-12">

        <div class="card-flat rounded-xl border border-skin-line p-6 sm:p-8" data-animate>
          <div class="section-label mb-2">{t.s1Num}</div>
          <h2 class="text-2xl font-bold tracking-tight">{t.s1Title}</h2>
          <p class="mt-3 max-w-3xl text-base text-skin-base/70 leading-relaxed">{t.s1Desc}</p>
          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            <div class="rounded-lg border border-skin-line bg-skin-card-muted p-4" data-animate data-animate-delay="100">
              <div class="text-sm font-semibold">{t.s1a}</div>
              <p class="mt-1 text-xs text-skin-base/60">{t.s1aDesc}</p>
            </div>
            <div class="rounded-lg border border-skin-line bg-skin-card-muted p-4" data-animate data-animate-delay="200">
              <div class="text-sm font-semibold">{t.s1b}</div>
              <p class="mt-1 text-xs text-skin-base/60">{t.s1bDesc}</p>
            </div>
            <div class="rounded-lg border border-skin-line bg-skin-card-muted p-4" data-animate data-animate-delay="300">
              <div class="text-sm font-semibold">{t.s1c}</div>
              <p class="mt-1 text-xs text-skin-base/60">{t.s1cDesc}</p>
            </div>
            <div class="rounded-lg border border-skin-line bg-skin-card-muted p-4" data-animate data-animate-delay="400">
              <div class="text-sm font-semibold">{t.s1d}</div>
              <p class="mt-1 text-xs text-skin-base/60">{t.s1dDesc}</p>
            </div>
          </div>
        </div>

        <div class="card-flat rounded-xl border border-skin-line p-6 sm:p-8" data-animate>
          <div class="section-label mb-2">{t.s2Num}</div>
          <h2 class="text-2xl font-bold tracking-tight">{t.s2Title}</h2>
          <p class="mt-3 max-w-3xl text-base text-skin-base/70 leading-relaxed">{t.s2Desc}</p>
          <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            <div class="rounded-lg border border-skin-line bg-skin-card-muted p-4" data-animate data-animate-delay="100">
              <div class="text-sm font-semibold">{t.s2a}</div>
              <p class="mt-1 text-xs text-skin-base/60">{t.s2aDesc}</p>
            </div>
            <div class="rounded-lg border border-skin-line bg-skin-card-muted p-4" data-animate data-animate-delay="200">
              <div class="text-sm font-semibold">{t.s2b}</div>
              <p class="mt-1 text-xs text-skin-base/60">{t.s2bDesc}</p>
            </div>
            <div class="rounded-lg border border-skin-line bg-skin-card-muted p-4" data-animate data-animate-delay="300">
              <div class="text-sm font-semibold">{t.s2c}</div>
              <p class="mt-1 text-xs text-skin-base/60">{t.s2cDesc}</p>
            </div>
          </div>
        </div>

        <div class="card-flat rounded-xl border border-skin-line p-6 sm:p-8" data-animate>
          <div class="section-label mb-2">{t.s3Num}</div>
          <h2 class="text-2xl font-bold tracking-tight">{t.s3Title}</h2>
          <p class="mt-3 max-w-3xl text-base text-skin-base/70 leading-relaxed">{t.s3Desc}</p>
          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            <div class="rounded-lg border border-skin-line bg-skin-card-muted p-4" data-animate data-animate-delay="100">
              <div class="text-sm font-semibold">{t.s3a}</div>
              <p class="mt-1 text-xs text-skin-base/60">{t.s3aDesc}</p>
            </div>
            <div class="rounded-lg border border-skin-line bg-skin-card-muted p-4" data-animate data-animate-delay="200">
              <div class="text-sm font-semibold">{t.s3b}</div>
              <p class="mt-1 text-xs text-skin-base/60">{t.s3bDesc}</p>
            </div>
            <div class="rounded-lg border border-skin-line bg-skin-card-muted p-4" data-animate data-animate-delay="300">
              <div class="text-sm font-semibold">{t.s3c}</div>
              <p class="mt-1 text-xs text-skin-base/60">{t.s3cDesc}</p>
            </div>
            <div class="rounded-lg border border-skin-line bg-skin-card-muted p-4" data-animate data-animate-delay="400">
              <div class="text-sm font-semibold">{t.s3d}</div>
              <p class="mt-1 text-xs text-skin-base/60">{t.s3dDesc}</p>
            </div>
          </div>
        </div>

      </div>

      <div class="mt-16 rounded-2xl bg-skin-card-muted p-8 text-center sm:p-12" data-animate>
        <h2 class="text-2xl font-bold tracking-tight">{t.ctaTitle}</h2>
        <p class="mx-auto mt-3 max-w-xl text-base text-skin-base/60">{t.ctaDesc}</p>
        <div class="mt-6">
          <a href="/contact/" class="btn-primary">{t.ctaBtn} &rarr;</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
