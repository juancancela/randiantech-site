---
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import LinkButton from "@components/LinkButton.astro";

const positions = [
  {
    title: "FullStack Developer",
    desc: "Tech Stack: React, Javascript, NodeJS, MongoDB, Heroku.",
  },
  {
    title: "Frontend Developer",
    desc: "Tech Stack: Python, React, Javascript, NodeJS, ExpressJS, MongoDB, Java.",
  },
  {
    title: "Backend Developer",
    desc: "Tech Stack: ReactJS, NodeJS, ExpressJS, MongoDB. GraphQL using Apollo Server and Apollo Client.",
  },
  {
    title: "QA Automation Engineer",
    desc: "Selenium Webdriver with Java, Cypress, WebdriverIO.",
  },
  {
    title: "QA Manual",
    desc: "Functional, Non functional, SQL, API testing.",
  },
  {
    title: "Sales Manager",
    desc: "Client bag.",
  },
];
---

<Layout title={`Careers | ${SITE.title}`}>
  <Header activeNav="careers" />
  <Breadcrumbs />
  <main id="main-content">
    <section class="site-container mb-16 mt-6">
      <div class="press-frame press-surface-white w-full p-6 sm:p-8">
        <h1 class="text-2xl tracking-wider sm:text-3xl">Careers</h1>

        <div class="prose mt-6 max-w-none">
          <p>
            We're always looking for talented people to join our team. If you're
            passionate about technology and want to work on challenging projects
            for US-based companies, take a look at our open positions below.
          </p>
        </div>

        <h2 class="section-label">Open Positions</h2>
        <div class="positions-grid">
          {positions.map((position) => (
            <a
              href={`mailto:info@randiantech.com?subject=I'm interested in the ${position.title} position`}
              class="position-card press-frame-subtle press-surface-paper p-5"
            >
              <div class="font-mono text-sm font-semibold">{position.title}</div>
              <div class="mt-2 font-serif text-sm leading-relaxed opacity-80">
                {position.desc}
              </div>
              <div class="mt-3 font-mono text-xs text-skin-accent">
                Apply &rarr;
              </div>
            </a>
          ))}
        </div>

        <div class="mt-10 press-frame press-surface-paper p-6 text-center">
          <h2 class="text-xl font-semibold">Don't see your role?</h2>
          <p class="mt-2 font-serif text-base opacity-80">
            We're always interested in hearing from great engineers. Send us your CV and let's talk.
          </p>
          <div class="mt-4">
            <LinkButton
              href="mailto:info@randiantech.com?subject=I'm interested to join the team!"
              className="inline-block border-2 border-skin-accent bg-skin-accent px-6 py-3 font-semibold text-white hover:opacity-85"
            >
              Get in touch &rarr;
            </LinkButton>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .section-label {
    @apply mt-8 mb-4 font-mono text-lg font-semibold tracking-wide;
  }

  .positions-grid {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .positions-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .position-card {
    @apply block no-underline text-skin-base transition-transform hover:scale-[1.02];
  }
</style>
