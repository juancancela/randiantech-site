---
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import translations from "../i18n/translations";

const t = translations.en.careers;

const positions = [
  {
    title: "AI Engineer",
    type: "Full-time · Remote",
    summary: "Build production AI systems — LLM integrations, RAG pipelines, and agent architectures.",
    description: `We're looking for an AI Engineer to design and build production-ready AI systems for our clients. You'll work on LLM integrations, RAG pipelines, autonomous agent architectures, and intelligent automation.

**What you'll do:**
- Design and implement LLM-powered features (chat, summarization, classification, generation)
- Build RAG systems with vector databases (Pinecone, Weaviate, pgvector)
- Develop multi-step agent workflows using LangChain, CrewAI, or custom frameworks
- Evaluate and fine-tune models for specific use cases
- Collaborate with client engineering teams to integrate AI into existing products

**What we're looking for:**
- 3+ years of software engineering experience
- 1+ year of hands-on experience with LLMs and AI/ML in production
- Strong Python skills; TypeScript is a plus
- Experience with OpenAI, Anthropic, or similar APIs
- Familiarity with vector databases and embedding models
- Solid understanding of prompt engineering and retrieval strategies`,
  },
  {
    title: "Full-Stack Developer",
    type: "Full-time · Remote",
    summary: "End-to-end product development with React, Node.js, TypeScript, and Python.",
    description: `We're hiring a Full-Stack Developer to join client teams and build modern web applications from end to end. You'll work on greenfield products and mature codebases alike, with a focus on quality, performance, and developer experience.

**What you'll do:**
- Build and maintain full-stack web applications (React, Next.js, Node.js)
- Design and implement REST and GraphQL APIs
- Work closely with product and design teams in agile sprints
- Write tests, participate in code reviews, and mentor junior developers
- Contribute to architecture decisions and technical roadmaps

**What we're looking for:**
- 5+ years of professional experience in full-stack development
- Expert-level TypeScript and React
- Strong backend skills (Node.js, Express, NestJS, or similar)
- Experience with relational and NoSQL databases
- Comfortable working in US timezones with English-speaking teams
- CI/CD, Docker, and cloud platform experience (AWS or GCP)`,
  },
  {
    title: "Data Engineer",
    type: "Full-time · Remote",
    summary: "Design data pipelines, build ETL processes, and enable AI-ready data infrastructure.",
    description: `We need a Data Engineer to help our clients build robust data infrastructure that powers analytics and AI systems. You'll design pipelines, manage data warehouses, and ensure data quality at scale.

**What you'll do:**
- Design and build scalable ETL/ELT pipelines
- Manage data warehouses (Snowflake, BigQuery, Redshift)
- Build streaming data pipelines with Kafka, Kinesis, or similar
- Implement data quality monitoring and validation
- Collaborate with AI engineers to prepare training data and feature stores

**What we're looking for:**
- 4+ years of experience in data engineering
- Strong SQL and Python skills
- Experience with Apache Spark, dbt, or Airflow
- Familiarity with cloud data platforms (AWS, GCP, or Azure)
- Understanding of data modeling and warehouse design
- Experience with streaming architectures is a plus`,
  },
  {
    title: "QA Automation Engineer",
    type: "Full-time · Remote",
    summary: "Build test automation frameworks and ensure product quality across the stack.",
    description: `We're looking for a QA Automation Engineer to build and maintain test automation frameworks for our client projects. You'll ensure quality across web, API, and mobile platforms.

**What you'll do:**
- Design and implement test automation strategies
- Build E2E test suites with Cypress, Playwright, or Selenium
- Create API test suites with Postman, REST Assured, or similar
- Integrate tests into CI/CD pipelines
- Perform performance and load testing when needed
- Collaborate with developers to improve testability and quality

**What we're looking for:**
- 4+ years of experience in QA with strong automation focus
- Expert in at least one modern test framework (Cypress, Playwright, Selenium)
- Strong programming skills (JavaScript/TypeScript or Java)
- Experience with CI/CD integration (GitHub Actions, Jenkins)
- API testing and performance testing experience
- Excellent attention to detail and communication skills`,
  },
  {
    title: "DevOps / Cloud Engineer",
    type: "Full-time · Remote",
    summary: "Build and manage cloud infrastructure, CI/CD pipelines, and deployment automation.",
    description: `We're hiring a DevOps/Cloud Engineer to help our clients build reliable, scalable infrastructure. You'll work on cloud architecture, CI/CD, containerization, and monitoring.

**What you'll do:**
- Design and manage cloud infrastructure on AWS, GCP, or Azure
- Build and maintain CI/CD pipelines (GitHub Actions, GitLab CI, Jenkins)
- Containerize applications with Docker and orchestrate with Kubernetes
- Implement infrastructure as code with Terraform or Pulumi
- Set up monitoring, alerting, and observability (Datadog, Grafana, CloudWatch)
- Ensure security best practices and compliance

**What we're looking for:**
- 4+ years of DevOps/Cloud engineering experience
- Strong experience with at least one major cloud provider
- Expert in Docker and Kubernetes
- Infrastructure as Code experience (Terraform preferred)
- Scripting skills (Bash, Python)
- Understanding of networking, security, and cost optimization`,
  },
];
---

<Layout title={`${t.label} | ${SITE.title}`}>
  <Header activeNav="careers" />
  <Breadcrumbs />
  <main id="main-content">
    <section class="site-container pt-6 pb-16">
      <div data-animate>
        <div class="section-label mb-3">{t.label}</div>
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{t.title}</h1>
        <p class="mt-4 max-w-2xl text-base text-skin-base/70">{t.desc}</p>
      </div>

      <h2 class="mt-12 mb-6 text-xl font-bold tracking-tight" data-animate>{t.openPositions}</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {positions.map((pos, i) => (
          <button
            class="card group text-left cursor-pointer job-card"
            data-job={JSON.stringify({ title: pos.title, type: pos.type, description: pos.description })}
            data-animate
            data-animate-delay={String((i + 1) * 100)}
          >
            <div class="text-base font-semibold group-hover:text-skin-accent transition-colors">{pos.title}</div>
            <div class="mt-1 text-xs text-skin-accent">{pos.type}</div>
            <p class="mt-3 text-sm text-skin-base/60">{pos.summary}</p>
            <div class="mt-4 text-xs font-medium text-skin-accent">View details &rarr;</div>
          </button>
        ))}
      </div>

      <div class="mt-16 rounded-2xl bg-skin-card-muted p-8 text-center sm:p-12" data-animate>
        <h2 class="text-2xl font-bold tracking-tight">{t.noRoleTitle}</h2>
        <p class="mx-auto mt-3 max-w-xl text-base text-skin-base/60">{t.noRoleDesc}</p>
        <div class="mt-6">
          <button id="open-apply-btn" class="btn-primary">{t.noRoleBtn} &rarr;</button>
        </div>
      </div>
    </section>

    <!-- Job Details Modal -->
    <div id="job-modal" class="modal-overlay hidden" role="dialog" aria-modal="true">
  <div class="modal-container">
    <div class="modal-header">
      <div>
        <h2 id="modal-title" class="text-xl font-bold"></h2>
        <p id="modal-type" class="mt-1 text-sm text-skin-accent"></p>
      </div>
      <button id="modal-close" class="modal-close-btn" aria-label="Close">&times;</button>
    </div>
    <div id="modal-body" class="modal-body prose max-w-none"></div>
    <div id="modal-apply-section" class="modal-footer">
      <div id="apply-form-wrapper">
        <p class="text-sm font-medium mb-3">Apply for this position</p>
        <div class="flex gap-3">
          <input type="url" id="modal-linkedin" placeholder="Your LinkedIn profile URL" class="form-input flex-1" />
          <button id="modal-apply-btn" class="btn-primary whitespace-nowrap">Apply &rarr;</button>
        </div>
        <p id="modal-apply-status" class="mt-3 text-sm hidden"></p>
      </div>
    </div>
  </div>
</div>

<!-- General Apply Modal (Don't see your role) -->
<div id="general-modal" class="modal-overlay hidden" role="dialog" aria-modal="true">
  <div class="modal-container">
    <div class="modal-header">
      <h2 class="text-xl font-bold">Join the team</h2>
      <button id="general-modal-close" class="modal-close-btn" aria-label="Close">&times;</button>
    </div>
    <div class="modal-body">
      <p class="text-sm text-skin-base/70">Send us your LinkedIn profile and we'll reach out if there's a match.</p>
    </div>
    <div class="modal-footer">
      <div class="flex gap-3">
        <input type="url" id="general-linkedin" placeholder="Your LinkedIn profile URL" class="form-input flex-1" />
        <button id="general-apply-btn" class="btn-primary whitespace-nowrap">Send &rarr;</button>
      </div>
      <p id="general-apply-status" class="mt-3 text-sm hidden"></p>
    </div>
  </div>
</div>

  </main>
  <Footer />
</Layout>

<style>
  .form-input {
    @apply w-full rounded-lg border border-skin-line bg-skin-card px-4 py-2.5 text-sm text-skin-base outline-none transition-colors placeholder:text-skin-base/30 focus:border-skin-accent;
  }
  .modal-overlay {
    @apply fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm p-4;
  }
  .modal-container {
    @apply w-full max-w-2xl max-h-[85vh] overflow-hidden rounded-2xl border border-skin-line bg-skin-fill shadow-2xl flex flex-col;
  }
  .modal-header {
    @apply flex items-start justify-between p-6 border-b border-skin-line;
  }
  .modal-close-btn {
    @apply text-2xl text-skin-base/40 hover:text-skin-base transition-colors leading-none;
  }
  .modal-body {
    @apply p-6 overflow-y-auto flex-1;
  }
  .modal-footer {
    @apply p-6 border-t border-skin-line;
  }
</style>

<script is:inline>
  (function() {
    function initCareers() {
      var jobModal = document.getElementById("job-modal");
      var generalModal = document.getElementById("general-modal");
      var modalTitle = document.getElementById("modal-title");
      var modalType = document.getElementById("modal-type");
      var modalBody = document.getElementById("modal-body");
      if (!jobModal || !generalModal) return;

      jobModal.classList.add("hidden");
      generalModal.classList.add("hidden");
      document.body.style.overflow = "";

      function openModal(modal) {
        modal.classList.remove("hidden");
        document.body.style.overflow = "hidden";
      }
      function closeModal(modal) {
        modal.classList.add("hidden");
        document.body.style.overflow = "";
      }

      function markdownToHtml(md) {
        return md
          .replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>")
          .replace(/^- (.+)$/gm, "<li>$1</li>")
          .replace(/\n\n/g, "</p><p>")
          .replace(/\n/g, "<br>");
      }

      document.querySelectorAll(".job-card").forEach(function(card) {
        card.onclick = function() {
          var data = JSON.parse(card.dataset.job || "{}");
          if (modalTitle) modalTitle.textContent = data.title;
          if (modalType) modalType.textContent = data.type;
          if (modalBody) modalBody.innerHTML = "<p>" + markdownToHtml(data.description || "") + "</p>";
          var li = document.getElementById("modal-linkedin");
          if (li) li.value = "";
          var st = document.getElementById("modal-apply-status");
          if (st) st.classList.add("hidden");
          openModal(jobModal);
        };
      });

      var closeBtn = document.getElementById("modal-close");
      if (closeBtn) closeBtn.onclick = function() { closeModal(jobModal); };

      var genCloseBtn = document.getElementById("general-modal-close");
      if (genCloseBtn) genCloseBtn.onclick = function() { closeModal(generalModal); };

      jobModal.onclick = function(e) { if (e.target === jobModal) closeModal(jobModal); };
      generalModal.onclick = function(e) { if (e.target === generalModal) closeModal(generalModal); };

      var openApplyBtn = document.getElementById("open-apply-btn");
      if (openApplyBtn) {
        openApplyBtn.onclick = function() {
          var li = document.getElementById("general-linkedin");
          if (li) li.value = "";
          var st = document.getElementById("general-apply-status");
          if (st) st.classList.add("hidden");
          openModal(generalModal);
        };
      }

      function submitApplication(role, linkedinInput, statusEl, btn) {
        var url = linkedinInput.value.trim();
        if (!url || url.indexOf("linkedin.com") === -1) {
          statusEl.textContent = "Please enter a valid LinkedIn URL";
          statusEl.className = "mt-3 text-sm text-red-500";
          return;
        }
        btn.disabled = true;
        btn.textContent = "Sending...";
        fetch("/api/apply", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ role: role, linkedinUrl: url }),
        }).then(function(res) {
          if (res.ok) {
            statusEl.textContent = "Application sent! We'll be in touch soon.";
            statusEl.className = "mt-3 text-sm text-green-600";
            linkedinInput.value = "";
          } else {
            throw new Error("Failed");
          }
        }).catch(function() {
          statusEl.textContent = "Something went wrong. Please try again.";
          statusEl.className = "mt-3 text-sm text-red-500";
        }).finally(function() {
          btn.disabled = false;
          btn.textContent = "Apply \u2192";
        });
      }

      var applyBtn = document.getElementById("modal-apply-btn");
      if (applyBtn) {
        applyBtn.onclick = function() {
          submitApplication(
            (modalTitle && modalTitle.textContent) || "Unknown",
            document.getElementById("modal-linkedin"),
            document.getElementById("modal-apply-status"),
            applyBtn
          );
        };
      }

      var genApplyBtn = document.getElementById("general-apply-btn");
      if (genApplyBtn) {
        genApplyBtn.onclick = function() {
          submitApplication(
            "General application",
            document.getElementById("general-linkedin"),
            document.getElementById("general-apply-status"),
            genApplyBtn
          );
        };
      }

      document.addEventListener("keydown", function(e) {
        if (e.key === "Escape") {
          closeModal(jobModal);
          closeModal(generalModal);
        }
      });
    }

    initCareers();
    document.addEventListener("astro:after-swap", initCareers);
  })();
</script>
