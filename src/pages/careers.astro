---
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const positions = [
  {
    title: "FullStack Developer",
    desc: "React, Javascript, NodeJS, MongoDB, Heroku.",
  },
  {
    title: "Frontend Developer",
    desc: "React, TypeScript, Next.js, modern CSS.",
  },
  {
    title: "Backend Developer",
    desc: "Node.js, Python, GraphQL, REST APIs, microservices.",
  },
  {
    title: "QA Automation Engineer",
    desc: "Selenium, Cypress, WebdriverIO, CI/CD integration.",
  },
  {
    title: "QA Manual",
    desc: "Functional, non-functional, SQL, API testing.",
  },
  {
    title: "AI/ML Engineer",
    desc: "LLM integration, RAG pipelines, agent architectures, Python.",
  },
];
---

<Layout title={`Careers | ${SITE.title}`}>
  <Header activeNav="careers" />
  <Breadcrumbs />
  <main id="main-content">
    <section class="site-container pt-6 pb-16">
      <div class="section-label mb-3">Join Us</div>
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Careers at Randiantech</h1>
      <p class="mt-4 max-w-2xl text-base text-skin-base/70">
        We're always looking for talented engineers who are passionate about building great software and exploring the frontier of AI.
      </p>

      <h2 class="mt-12 mb-6 text-xl font-bold tracking-tight">Open Positions</h2>
      <div class="grid gap-3 sm:grid-cols-2">
        {positions.map((position) => (
          <a
            href={`mailto:info@randiantech.com?subject=I'm interested in the ${position.title} position`}
            class="card group"
          >
            <div class="text-base font-semibold group-hover:text-skin-accent transition-colors">{position.title}</div>
            <p class="mt-2 text-sm text-skin-base/60">{position.desc}</p>
            <div class="mt-3 text-xs font-medium text-skin-accent">Apply &rarr;</div>
          </a>
        ))}
      </div>

      <div class="mt-16 rounded-2xl bg-skin-card-muted p-8 text-center sm:p-12">
        <h2 class="text-2xl font-bold tracking-tight">
          Don't see your role?
        </h2>
        <p class="mx-auto mt-3 max-w-xl text-base text-skin-base/60">
          We're always interested in hearing from great engineers. Send us your CV and let's talk.
        </p>
        <div class="mt-6">
          <a
            href="mailto:info@randiantech.com?subject=I'm interested to join the team!"
            class="btn-primary"
          >
            Get in touch &rarr;
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
