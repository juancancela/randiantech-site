---
import Breadcrumbs from "@components/Breadcrumbs.astro";

export interface Props {
  pageTitle: string;
  pageDesc?: string;
}

const { pageTitle, pageDesc } = Astro.props;
---

<Breadcrumbs />
<main id="main-content">
  <section class="press-frame-subtle press-surface-white page-frame">
    <h1>{pageTitle}</h1>
    {pageDesc && <p>{pageDesc}</p>}
    <slot />
  </section>
</main>

<style>
  #main-content {
    @apply mx-auto w-full max-w-3xl px-4 pb-4;
  }
  .page-frame {
    @apply mt-6 p-6 sm:p-8;
  }
  #main-content h1 {
    @apply text-2xl font-semibold sm:text-3xl;
  }
  #main-content p {
    @apply mb-6 mt-2 italic;
  }
</style>
